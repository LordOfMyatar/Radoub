<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="Manifest.Views.SettingsWindow"
        Title="Settings - Manifest"
        Icon="avares://Manifest/Assets/manifest.ico"
        Width="500" Height="620"
        MinWidth="400" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="15" Margin="0,0,15,0">
                <!-- Module Configuration (#1325, #1322) -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Module Configuration" FontWeight="Bold"/>
                        <TextBlock Text="Module selection is managed through Trebuchet (the Radoub launcher). All tools share the same active module."
                                  TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0" Text="Active Module: " VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="CurrentModuleText" Grid.Column="1"
                                      Text="(checking...)"
                                      VerticalAlignment="Center"
                                      TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <Button x:Name="ConfigureInTrebuchetButton"
                               Content="Configure in Trebuchet..."
                               Click="OnConfigureInTrebuchetClick"
                               HorizontalAlignment="Left" Padding="10,5"/>
                        <TextBlock x:Name="TrebuchetStatusText"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Game Paths Settings -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Game Paths" FontWeight="Bold"/>
                        <TextBlock Text="Configure Neverwinter Nights paths for TLK string resolution and resource loading."
                                  TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- Base Game Installation -->
                        <TextBlock Text="Base Game Installation (Steam/GOG)" FontWeight="Normal" Margin="0,5,0,0"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox x:Name="GamePathTextBox"
                                    Grid.Column="0"
                                    Watermark="C:\Program Files (x86)\Steam\steamapps\common\Neverwinter Nights"
                                    TextChanged="OnGamePathTextChanged"/>
                            <Button Grid.Column="1" Content="…" ToolTip.Tip="Browse for game folder"
                                   Click="OnBrowseGamePath" Margin="5,0,0,0" Width="32"/>
                            <Button Grid.Column="2" Content="⌕" ToolTip.Tip="Auto-detect game path"
                                   Click="OnAutoDetectGamePath" Margin="5,0,0,0" Width="32"/>
                        </Grid>
                        <TextBlock x:Name="GamePathValidationText"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- User Documents Path -->
                        <TextBlock Text="User Documents (modules, override, TLKs)" FontWeight="Normal" Margin="0,10,0,0"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox x:Name="UserPathTextBox"
                                    Grid.Column="0"
                                    Watermark="~/Documents/Neverwinter Nights"
                                    TextChanged="OnUserPathTextChanged"/>
                            <Button Grid.Column="1" Content="…" ToolTip.Tip="Browse for user folder"
                                   Click="OnBrowseUserPath" Margin="5,0,0,0" Width="32"/>
                            <Button Grid.Column="2" Content="⌕" ToolTip.Tip="Auto-detect user path"
                                   Click="OnAutoDetectUserPath" Margin="5,0,0,0" Width="32"/>
                        </Grid>
                        <TextBlock x:Name="UserPathValidationText"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Theme & Font (managed by Trebuchet) -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Theme &amp; Font" FontWeight="Bold"/>
                        <TextBlock Text="Theme and font settings are managed centrally in Trebuchet."
                                  TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Spell Check Settings -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Spell Check" FontWeight="Bold"/>
                        <TextBlock Text="Configure spell-checking for journal text. Custom dictionary is shared with other Radoub tools."
                                  TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- Enable/Disable -->
                        <CheckBox x:Name="SpellCheckEnabledCheckBox"
                                 Content="Enable spell checking"
                                 Checked="OnSpellCheckEnabledChanged"
                                 Unchecked="OnSpellCheckEnabledChanged"/>

                        <!-- Dictionary Info -->
                        <TextBlock x:Name="DictionaryInfoText"
                                  Text="Custom dictionary: 0 words"
                                  FontSize="{DynamicResource FontSizeSmall}"
                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Dictionaries Settings -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Dictionaries" FontWeight="Bold"/>
                        <TextBlock Text="Select the language dictionary for spell checking. Add custom dictionaries to ~/Radoub/Dictionaries/."
                                  TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                        <!-- Primary Language -->
                        <TextBlock Text="Primary Language" FontWeight="Normal" Margin="0,5,0,0"/>
                        <ComboBox x:Name="PrimaryLanguageComboBox"
                                 SelectionChanged="OnPrimaryLanguageChanged"
                                 HorizontalAlignment="Stretch"/>

                        <!-- Custom Dictionaries -->
                        <TextBlock Text="Custom Dictionaries" FontWeight="Normal" Margin="0,10,0,0"/>
                        <ListBox x:Name="CustomDictionariesListBox"
                                MinHeight="80"
                                MaxHeight="200"
                                Background="Transparent"/>

                        <!-- Dictionary Actions -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                            <Button Content="Open Folder"
                                   ToolTip.Tip="Open dictionaries folder in file explorer"
                                   Click="OnOpenDictionariesFolderClick"/>
                            <Button Content="↻ Refresh"
                                   ToolTip.Tip="Rescan for new dictionaries"
                                   Click="OnRefreshDictionariesClick"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="2" Content="Close" Click="OnCloseClick"
                HorizontalAlignment="Right" Width="80" Margin="0,15,0,0"/>
    </Grid>
</Window>
