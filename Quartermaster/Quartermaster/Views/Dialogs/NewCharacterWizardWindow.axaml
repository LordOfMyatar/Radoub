<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Quartermaster.Views.Dialogs.NewCharacterWizardWindow"
        Title="New Character Wizard"
        AutomationProperties.AutomationId="NewCharacterWizardWindow"
        MinWidth="900" MinHeight="650"
        Width="1000" Height="750"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackground}">

    <Window.Styles>
        <!-- Dark mode selection visibility fix -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Step indicator styles -->
        <Style Selector="Border.step-indicator">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Border.step-indicator.current">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="Border.step-indicator.completed">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        </Style>
        <!-- File type card styles -->
        <Style Selector="Border.file-type-card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.file-type-card.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left Sidebar: Step Navigator -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="10">
            <StackPanel>
                <!-- Header -->
                <TextBlock x:Name="SidebarTitle"
                           Text="New Character"
                           FontSize="{DynamicResource FontSizeMedium}"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="SidebarSummary"
                           Text="Choose your path..."
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Step Indicators -->
                <TextBlock Text="Steps" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Border x:Name="Step1Border" Classes="step-indicator current">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step1Number" Text="1" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="File Type"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step2Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step2Number" Text="2" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Race &amp; Sex"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step3Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step3Number" Text="3" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Identity"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step4Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step4Number" Text="4" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Appearance"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step5Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step5Number" Text="5" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Class"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step6Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step6Number" Text="6" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Abilities"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step7Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step7Number" Text="7" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Feats"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step8Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step8Number" Text="8" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Skills"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step9Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step9Number" Text="9" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Spells"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step10Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step10Number" Text="10" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Equipment"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step11Border" Classes="step-indicator">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="Step11Number" Text="11" FontWeight="Bold" Width="20"/>
                        <TextBlock Text="Summary"/>
                    </StackPanel>
                </Border>

                <!-- Validation Level Toggle (#1503) -->
                <Separator Margin="0,15,0,10"/>
                <TextBlock Text="Rules" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ValidationLevelComboBox"
                          AutomationProperties.AutomationId="ValidationLevelComboBox"
                          HorizontalAlignment="Stretch"
                          SelectedIndex="1">
                    <ComboBoxItem Content="😈 Chaotic Evil" ToolTip.Tip="No validation. Anything goes — for power users and custom content."/>
                    <ComboBoxItem Content="⚖️ True Neutral" ToolTip.Tip="Warn about rule violations but allow them. Default."/>
                    <ComboBoxItem Content="⚔️ Lawful Good" ToolTip.Tip="Enforce ELC rules. Block invalid selections."/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="15">

            <!-- Step 1: File Type -->
            <Grid x:Name="Step1Panel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="What are you creating?" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Choose the type of character file. This determines which options are available."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,25"/>

                <StackPanel Grid.Row="2" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                        <!-- UTC Card -->
                        <Border x:Name="UtcCard" Classes="file-type-card selected" PointerPressed="OnUtcCardClick" Width="280">
                            <StackPanel Spacing="10">
                                <TextBlock Text="NPC" FontSize="{DynamicResource FontSizeTitle}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Creature Blueprint (.utc)" FontSize="{DynamicResource GlobalFontSize}" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="0,5"/>
                                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           Text="A creature blueprint for module building. All races and classes available. Stats editable after creation."/>
                            </StackPanel>
                        </Border>

                        <!-- BIC Card -->
                        <Border x:Name="BicCard" Classes="file-type-card" PointerPressed="OnBicCardClick" Width="280">
                            <StackPanel Spacing="10">
                                <TextBlock Text="PC" FontSize="{DynamicResource FontSizeTitle}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Player Character (.bic)" FontSize="{DynamicResource GlobalFontSize}" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="0,5"/>
                                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           Text="A player character file. Uses player races and classes only, with standard 30-point ability buy."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Default Scripts option (UTC only) -->
                    <StackPanel x:Name="DefaultScriptsPanel" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" Margin="0,10,0,0">
                        <CheckBox x:Name="DefaultScriptsCheckBox" IsChecked="True"
                                  Content="Load default NWN scripts (nw_c2_default*)"/>
                    </StackPanel>

                    <!-- Save Location -->
                    <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,10,0,0" MaxWidth="580">
                        <TextBlock Text="Save Location" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBox x:Name="SaveLocationTextBox" Grid.Column="0" IsReadOnly="True"
                                     Watermark="Click Browse to choose save location..."
                                     Margin="0,0,8,0"/>
                            <Button x:Name="BrowseSaveLocationButton" Grid.Column="1"
                                    Content="Browse..." Click="OnBrowseSaveLocationClick"/>
                        </Grid>
                        <TextBlock x:Name="SaveLocationNote" FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap" HorizontalAlignment="Center"
                                   Text="Choose where to save before building your character."/>
                    </StackPanel>

                    <!-- Starting Level -->
                    <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,10,0,0" MaxWidth="580">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <TextBlock Text="Starting Level" FontWeight="Bold" VerticalAlignment="Center"/>
                            <NumericUpDown x:Name="StartingLevelSpinner"
                                           Minimum="1" Maximum="40" Value="1"
                                           Width="100" FormatString="0"/>
                        </StackPanel>
                        <TextBlock x:Name="StartingLevelNote" FontSize="{DynamicResource FontSizeSmall}"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap" HorizontalAlignment="Center"
                                   Text="Level 1 character. Change to create at a higher level (single class only)."
                                   IsVisible="True"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Step 2: Race & Sex -->
            <Grid x:Name="Step2Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Choose Race &amp; Sex" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Your race determines ability modifiers, size, and favored class."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Sex toggle + Race list -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Sex Toggle (prominent, at top) -->
                        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                Padding="10,8" CornerRadius="4" Margin="0,0,10,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Sex:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <ToggleButton x:Name="MaleToggle" Content="Male" IsChecked="True"
                                              Click="OnMaleToggleClick" Width="80"/>
                                <ToggleButton x:Name="FemaleToggle" Content="Female" IsChecked="False"
                                              Click="OnFemaleToggleClick" Width="80"/>
                            </StackPanel>
                        </Border>

                        <TextBox Grid.Row="1" x:Name="RaceSearchBox"
                                 Watermark="Filter races..."
                                 Margin="0,0,10,5"
                                 TextChanged="OnRaceSearchChanged"/>

                        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" Margin="0,0,10,0">
                            <ListBox x:Name="RaceListBox" SelectionChanged="OnRaceSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Margin="5,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Right: Racial info panel -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" Padding="15">
                        <Grid x:Name="RaceInfoPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" x:Name="SelectedRaceNameLabel"
                                       Text="Select a race"
                                       FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" Margin="0,0,0,15"/>

                            <!-- Ability Modifiers -->
                            <Border Grid.Row="1" x:Name="RaceModifiersPanel"
                                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="12" CornerRadius="4" Margin="0,0,0,10" IsVisible="False">
                                <StackPanel>
                                    <TextBlock Text="Ability Modifiers" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid x:Name="ModifiersGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Column="0" Grid.Row="0" x:Name="StrModLabel" Text="STR: +0" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="1" Grid.Row="0" x:Name="DexModLabel" Text="DEX: +0" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="2" Grid.Row="0" x:Name="ConModLabel" Text="CON: +0" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="0" Grid.Row="1" x:Name="IntModLabel" Text="INT: +0" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="1" Grid.Row="1" x:Name="WisModLabel" Text="WIS: +0" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="2" Grid.Row="1" x:Name="ChaModLabel" Text="CHA: +0" FontWeight="SemiBold" Margin="0,2"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Favored Class & Size -->
                            <StackPanel Grid.Row="2" x:Name="RaceTraitsPanel" Spacing="5" Margin="0,0,0,10" IsVisible="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Favored Class:" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="FavoredClassLabel" Text="Any"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Size:" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="RaceSizeLabel" Text="Medium"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Race Description -->
                            <Border Grid.Row="3" Height="1"
                                    Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                    Margin="0,0,0,10" x:Name="RaceDescSeparator" IsVisible="False"/>

                            <ScrollViewer Grid.Row="4">
                                <TextBlock x:Name="RaceDescriptionLabel"
                                           TextWrapping="Wrap"
                                           Text="Select a race to see its details."
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Step 3: Identity -->
            <Grid x:Name="Step3Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Character Identity" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Name your character, choose a portrait and voice set."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Identity Fields -->
                        <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,20,0">
                            <!-- Name -->
                            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="12" CornerRadius="4">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="100,*" RowSpacing="8" ColumnSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="First Name:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="IdentityFirstNameTextBox"
                                             Watermark="Enter character name..."
                                             TextChanged="OnIdentityNameChanged"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Name:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="IdentityLastNameTextBox"
                                             Watermark="(optional)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="IdentityAgeLabelText" Text="Age:" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <NumericUpDown x:Name="IdentityAgeNumericUpDown"
                                                       Minimum="1" Maximum="9999" Value="25"
                                                       HorizontalAlignment="Left" Width="100"
                                                       FormatString="0"/>
                                        <TextBlock x:Name="IdentityAgeNote" Text="(BIC only)"
                                                   VerticalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="IdentityDescriptionTextBox"
                                             Watermark="(optional) Character biography or description..."
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="80"/>
                                </Grid>
                            </Border>

                            <!-- Voice Set -->
                            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="12" CornerRadius="4">
                                <Grid ColumnDefinitions="100,*,Auto" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Voice Set:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="IdentityVoiceSetLabel" Text="None" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" x:Name="IdentityBrowseVoiceSetButton" Content="Browse..."
                                            Click="OnBrowseVoiceSetClick"/>
                                </Grid>
                            </Border>

                            <!-- Filename / ResRef Preview -->
                            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="12" CornerRadius="4">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Generated Identifiers" FontWeight="Bold"/>
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="80,*" RowSpacing="4" ColumnSpacing="10">
                                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="IdentityTagLabelText" Text="Tag:"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="IdentityGeneratedTagLabel" Text="new_creature"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ResRef:"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="IdentityGeneratedResRefLabel" Text="new_creature"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </Grid>
                                    <TextBlock x:Name="IdentityFilenameWarning" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}"
                                               IsVisible="False"/>
                                </StackPanel>
                            </Border>

                            <!-- UTC-only fields -->
                            <Border x:Name="IdentityUtcFieldsPanel" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="12" CornerRadius="4">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="100,*" RowSpacing="8" ColumnSpacing="10">
                                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="IdentityPaletteIdLabelText" Text="Palette:"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="IdentityPaletteIdComboBox"
                                              HorizontalAlignment="Left" MinWidth="250"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="IdentityFactionLabelText" Text="Faction:"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="IdentityFactionComboBox"
                                              HorizontalAlignment="Left" MinWidth="250"
                                              SelectionChanged="OnFactionSelectionChanged"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Right: Portrait -->
                        <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" Padding="12" Width="180" VerticalAlignment="Top">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Portrait" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1" Width="128" Height="160" HorizontalAlignment="Center">
                                    <Image x:Name="IdentityPortraitPreviewImage" Stretch="Uniform"/>
                                </Border>
                                <TextBlock x:Name="IdentityPortraitNameLabel" Text="No portrait selected"
                                           HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                                <Button x:Name="IdentityBrowsePortraitButton" Content="Browse..."
                                        Click="OnBrowsePortraitClick" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Step 4: Appearance -->
            <Grid x:Name="Step4Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Customize Appearance" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Choose your character's appearance type, phenotype, and body details."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Appearance/Phenotype/Portrait -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10" Margin="0,0,15,15">
                        <!-- Appearance -->
                        <TextBlock Text="Appearance Type" FontWeight="SemiBold"/>
                        <TextBox x:Name="AppearanceSearchBox" Watermark="Filter appearances..."
                                 Margin="0,0,0,3" TextChanged="OnAppearanceSearchChanged"/>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" MaxHeight="160">
                            <ListBox x:Name="AppearanceListBox" SelectionChanged="OnAppearanceSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Margin="4,1"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Phenotype -->
                        <TextBlock Text="Phenotype" FontWeight="SemiBold"/>
                        <ComboBox x:Name="PhenotypeComboBox" HorizontalAlignment="Stretch"
                                  SelectionChanged="OnPhenotypeSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Colors Section -->
                        <TextBlock Text="Colors" FontWeight="SemiBold" Margin="0,5,0,0"/>
                        <Grid ColumnDefinitions="70,56,20,70,56,20" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="4">
                            <!-- Row 0: Skin / Hair -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Skin:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1" x:Name="SkinColorNumericUpDown"
                                           Minimum="0" Maximum="175" Value="0" FormatString="0"
                                           Width="56" ValueChanged="OnColorValueChanged"/>
                            <Border Grid.Row="0" Grid.Column="2" x:Name="SkinColorSwatch" Width="18" Height="18"
                                    CornerRadius="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="OnSkinColorSwatchClick"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Hair:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="4" x:Name="HairColorNumericUpDown"
                                           Minimum="0" Maximum="175" Value="0" FormatString="0"
                                           Width="56" ValueChanged="OnColorValueChanged"/>
                            <Border Grid.Row="0" Grid.Column="5" x:Name="HairColorSwatch" Width="18" Height="18"
                                    CornerRadius="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="OnHairColorSwatchClick"/>
                            <!-- Row 1: Tattoo 1 / Tattoo 2 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tattoo 1:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="Tattoo1ColorNumericUpDown"
                                           Minimum="0" Maximum="175" Value="0" FormatString="0"
                                           Width="56" ValueChanged="OnColorValueChanged"/>
                            <Border Grid.Row="1" Grid.Column="2" x:Name="Tattoo1ColorSwatch" Width="18" Height="18"
                                    CornerRadius="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="OnTattoo1ColorSwatchClick"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Tattoo 2:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="4" x:Name="Tattoo2ColorNumericUpDown"
                                           Minimum="0" Maximum="175" Value="0" FormatString="0"
                                           Width="56" ValueChanged="OnColorValueChanged"/>
                            <Border Grid.Row="1" Grid.Column="5" x:Name="Tattoo2ColorSwatch" Width="18" Height="18"
                                    CornerRadius="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1"
                                    Cursor="Hand" PointerPressed="OnTattoo2ColorSwatchClick"/>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>

                    <!-- Right: Body Parts -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" Padding="12">
                        <Grid x:Name="BodyPartsPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Body Parts" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,8"/>

                            <ScrollViewer Grid.Row="1">
                                <StackPanel x:Name="BodyPartsContent" Spacing="4" Margin="0,0,15,0">
                                    <!-- Core body parts - 2-column compact layout -->
                                    <Grid ColumnDefinitions="60,*,60,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                                        <!-- Row 0: Head / Neck -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Head:" FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1" x:Name="HeadNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Neck:" FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="3" x:Name="NeckNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Row 1: Torso / Pelvis -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Torso:" FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="TorsoNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Pelvis:" FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="3" x:Name="PelvisNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Row 2: Belt / L Shoulder -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Belt:" FontSize="{DynamicResource FontSizeXSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1" x:Name="BeltNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="0" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                    </Grid>

                                    <!-- Limbs Section -->
                                    <TextBlock Text="Limbs" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeXSmall}" Margin="0,4,0,2"/>
                                    <Grid ColumnDefinitions="60,*,60,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="6">
                                        <!-- Shoulders -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="L Shoul:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1" x:Name="LShoulNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="0" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="R Shoul:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="3" x:Name="RShoulNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="0" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Biceps -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="L Bicep:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1" x:Name="LBicepNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="R Bicep:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="3" x:Name="RBicepNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Forearms -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="L FArm:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1" x:Name="LFArmNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="R FArm:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="3" x:Name="RFArmNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Hands -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="L Hand:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="1" x:Name="LHandNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="R Hand:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="3" x:Name="RHandNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Thighs -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="L Thigh:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="4" Grid.Column="1" x:Name="LThighNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="R Thigh:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="4" Grid.Column="3" x:Name="RThighNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Shins -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="L Shin:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="5" Grid.Column="1" x:Name="LShinNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="R Shin:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="5" Grid.Column="3" x:Name="RShinNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <!-- Feet -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="L Foot:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="6" Grid.Column="1" x:Name="LFootNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                        <TextBlock Grid.Row="6" Grid.Column="2" Text="R Foot:" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <NumericUpDown Grid.Row="6" Grid.Column="3" x:Name="RFootNumericUpDown"
                                                       Minimum="0" Maximum="255" Value="1" FormatString="0" ValueChanged="OnBodyPartChanged"/>
                                    </Grid>

                                    <!-- Non-part-based notice -->
                                    <TextBlock x:Name="BodyPartsNotApplicableLabel"
                                               Text="Body part customization is only available for humanoid appearance types."
                                               TextWrapping="Wrap" IsVisible="False"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               FontStyle="Italic" Margin="0,6"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Advisory note about visualization -->
                <Border Grid.Row="3" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="8" CornerRadius="4" Margin="0,8,0,0">
                    <TextBlock Text="More visualization options (3D preview, head gallery) are available on the Appearance panel after creating the character."
                               TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" FontStyle="Italic"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </Border>
            </Grid>

            <!-- Step 5: Class & Package -->
            <Grid x:Name="Step5Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Choose Class &amp; Package" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Select your starting class. The package determines recommended skills and feats."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Class List -->
                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" x:Name="ClassSearchBox"
                                 Watermark="Filter classes..."
                                 Margin="0,0,0,5"
                                 TextChanged="OnClassSearchChanged"/>

                        <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1">
                            <ListBox x:Name="ClassListBox" SelectionChanged="OnClassSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5,2,16,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                            <TextBlock Grid.Column="1" x:Name="FavoredBadge"
                                                       Text="★" FontSize="{DynamicResource GlobalFontSize}"
                                                       ToolTip.Tip="Racial favored class"
                                                       IsVisible="{Binding IsFavored}"
                                                       Foreground="{DynamicResource SystemAccentColor}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Right: Class Detail + Package -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" Padding="15">
                        <ScrollViewer Padding="0,0,8,0">
                            <Grid x:Name="ClassDetailPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Class Name -->
                                <TextBlock Grid.Row="0" x:Name="SelectedClassNameLabel"
                                           Text="Select a class"
                                           FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" Margin="0,0,0,10"/>

                                <!-- Stats Grid -->
                                <Border Grid.Row="1" x:Name="ClassStatsPanel"
                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        Padding="12" CornerRadius="4" Margin="0,0,0,10" IsVisible="False">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0" Grid.Row="0" x:Name="ClassHitDieLabel" Text="Hit Die: d8" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="1" Grid.Row="0" x:Name="ClassSkillPointsLabel" Text="Skill Points: 2" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="0" Grid.Row="1" x:Name="ClassPrimaryAbilityLabel" Text="Primary: —" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="1" Grid.Row="1" x:Name="ClassCasterLabel" Text="Spellcasting: None" FontWeight="SemiBold" Margin="0,2"/>
                                        <TextBlock Grid.Column="0" Grid.Row="2" x:Name="ClassAlignmentLabel" Text="" Margin="0,2"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextWrapping="Wrap"
                                                   Grid.ColumnSpan="2"/>
                                    </Grid>
                                </Border>

                                <!-- Starting Package -->
                                <StackPanel Grid.Row="2" x:Name="PackageSection" Spacing="5" Margin="0,0,0,10" IsVisible="False">
                                    <TextBlock Text="Starting Package" FontWeight="Bold"/>
                                    <ComboBox x:Name="PackageComboBox" HorizontalAlignment="Stretch"
                                              SelectionChanged="OnPackageSelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Description separator -->
                                <Border Grid.Row="3" Height="1"
                                        Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        Margin="0,0,0,10" x:Name="ClassDescSeparator" IsVisible="False"/>

                                <!-- Domain Selection (Cleric) -->
                                <StackPanel Grid.Row="4" x:Name="DomainSelectionPanel" Spacing="5" Margin="0,0,0,10" IsVisible="False">
                                    <TextBlock Text="Deity Domains" FontWeight="Bold"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Domain 1" Margin="0,0,0,3"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Grid.Column="2" Grid.Row="0" Text="Domain 2" Margin="0,0,0,3"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <ComboBox Grid.Column="0" Grid.Row="1" x:Name="Domain1ComboBox" HorizontalAlignment="Stretch"
                                                 SelectionChanged="OnDomainSelectionChanged"/>
                                        <ComboBox Grid.Column="2" Grid.Row="1" x:Name="Domain2ComboBox" HorizontalAlignment="Stretch"
                                                 SelectionChanged="OnDomainSelectionChanged"/>
                                    </Grid>
                                    <!-- Domain Info Display -->
                                    <TextBlock x:Name="DomainInfoLabel" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               IsVisible="False" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Familiar Selection (Wizard/Sorcerer) -->
                                <StackPanel Grid.Row="5" x:Name="FamiliarSelectionPanel" Spacing="5" Margin="0,0,0,10" IsVisible="False">
                                    <TextBlock Text="Familiar" FontWeight="Bold"/>
                                    <ComboBox x:Name="FamiliarComboBox" HorizontalAlignment="Stretch"
                                              SelectionChanged="OnFamiliarSelectionChanged"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                                        <TextBlock Text="Name:" VerticalAlignment="Center"/>
                                        <TextBox x:Name="FamiliarNameTextBox" MinWidth="200" Watermark="(unnamed)"/>
                                    </StackPanel>
                                    <TextBlock Text="Your familiar is a magical companion that aids you."
                                               FontSize="{DynamicResource FontSizeSmall}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>

                                <!-- Alignment Selection -->
                                <StackPanel Grid.Row="6" x:Name="AlignmentSelectionPanel" Spacing="5" Margin="0,0,0,10">
                                    <TextBlock Text="Alignment" FontWeight="Bold"/>
                                    <Grid x:Name="AlignmentGrid" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Column headers -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Lawful" HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Neutral" HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,3"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Chaotic" HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,3"/>
                                        <!-- Row 1: Good -->
                                        <ToggleButton Grid.Row="1" Grid.Column="0" x:Name="AlignLG" Content="LG" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Lawful Good"/>
                                        <ToggleButton Grid.Row="1" Grid.Column="1" x:Name="AlignNG" Content="NG" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Neutral Good"/>
                                        <ToggleButton Grid.Row="1" Grid.Column="2" x:Name="AlignCG" Content="CG" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Chaotic Good"/>
                                        <!-- Row 2: Neutral -->
                                        <ToggleButton Grid.Row="2" Grid.Column="0" x:Name="AlignLN" Content="LN" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Lawful Neutral"/>
                                        <ToggleButton Grid.Row="2" Grid.Column="1" x:Name="AlignTN" Content="TN" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" IsChecked="True" ToolTip.Tip="True Neutral"/>
                                        <ToggleButton Grid.Row="2" Grid.Column="2" x:Name="AlignCN" Content="CN" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Chaotic Neutral"/>
                                        <!-- Row 3: Evil -->
                                        <ToggleButton Grid.Row="3" Grid.Column="0" x:Name="AlignLE" Content="LE" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Lawful Evil"/>
                                        <ToggleButton Grid.Row="3" Grid.Column="1" x:Name="AlignNE" Content="NE" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Neutral Evil"/>
                                        <ToggleButton Grid.Row="3" Grid.Column="2" x:Name="AlignCE" Content="CE" Width="80" HorizontalContentAlignment="Center"
                                                      Margin="2" Click="OnAlignmentClick" ToolTip.Tip="Chaotic Evil"/>
                                    </Grid>
                                    <TextBlock x:Name="AlignmentRestrictionWarning" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               IsVisible="False"/>
                                </StackPanel>

                                <!-- Class Description -->
                                <ScrollViewer Grid.Row="7" MaxHeight="200">
                                    <TextBlock x:Name="ClassDescriptionLabel"
                                               TextWrapping="Wrap"
                                               Text="Select a class to see its details."
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </ScrollViewer>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Prestige Planning (collapsible) -->
                <Border Grid.Row="3" x:Name="PrestigePlanningBorder"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="10" CornerRadius="4" Margin="0,10,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock x:Name="PrestigeToggleArrow" Text="▸" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="Prestige Planning (Advisory)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border x:Name="PrestigeToggleClickArea" Background="Transparent" Margin="-10,-5,-10,0" Padding="10,5,10,0"
                                PointerPressed="OnPrestigePlanningToggle" Cursor="Hand" Height="5"/>
                        <StackPanel x:Name="PrestigePlanningContent" IsVisible="False" Margin="0,5,0,0" Spacing="5">
                            <TextBlock Text="Select a prestige class goal to see its prerequisites:"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       FontSize="{DynamicResource FontSizeSmall}"/>
                            <ComboBox x:Name="PrestigeClassComboBox" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnPrestigeClassSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock x:Name="PrestigePrereqLabel"
                                       TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Step 6: Ability Scores -->
            <Grid x:Name="Step6Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Assign Ability Scores" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" x:Name="AbilityStepSubtitle" Text="Distribute 30 points across your abilities. Base scores start at 8. Higher scores cost more points."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Points Remaining -->
                <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="12" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Points Remaining:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AbilityPointsRemainingLabel" Text="30" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="AbilityAutoAssignButton" Content="Auto-Assign" Click="OnAbilityAutoAssignClick"/>
                    </Grid>
                </Border>

                <!-- Prestige Advisory Banner -->
                <Border Grid.Row="3" x:Name="PrestigeAbilityBanner"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="8" CornerRadius="4" Margin="0,0,0,10" IsVisible="False">
                    <TextBlock x:Name="PrestigeAbilityBannerLabel" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}" FontStyle="Italic"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </Border>

                <!-- Ability Score Grid -->
                <Border Grid.Row="4" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ability" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Base" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Racial" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="Total" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="Mod" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="Cost" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Ability Rows -->
                        <StackPanel Grid.Row="1" x:Name="AbilityRowsPanel" Spacing="6"/>
                    </Grid>
                </Border>

                <!-- Cost Reference -->
                <Border Grid.Row="5" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="8" CornerRadius="4" Margin="0,8,0,0">
                    <TextBlock Text="Cost table: 8→0  9→1  10→2  11→3  12→4  13→5  14→6  15→8  16→10  17→13  18→16"
                               FontSize="{DynamicResource FontSizeSmall}" FontFamily="Consolas"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </Border>
            </Grid>

            <!-- Step 7: Feats -->
            <Grid x:Name="Step7Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select Feats" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" x:Name="FeatStepDescription"
                           Text="Choose your starting feats. Granted feats from your race and class are pre-selected."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Feat Selection Counter + Auto-Assign -->
                <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="12" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Feats to Choose:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FeatSelectionCountLabel" Text="0 / 0" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="FeatAutoAssignButton" Content="Auto-Assign" Click="OnFeatAutoAssignClick"/>
                    </Grid>
                </Border>

                <!-- Two-panel feat selection -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Available Feats -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Available Feats" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" x:Name="FeatSearchBox" Watermark="Filter feats..."
                                 Margin="0,0,0,5" TextChanged="OnFeatSearchChanged"/>
                        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1">
                            <ListBox x:Name="AvailableFeatsListBox" SelectionMode="Multiple,Toggle"
                                     SelectionChanged="OnAvailableFeatSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2,16,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CategoryAbbrev}" FontSize="{DynamicResource FontSizeXSmall}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Center: Add/Remove Buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="AddFeatButton" Content="▶" Width="40" HorizontalContentAlignment="Center"
                                Click="OnAddFeatClick" ToolTip.Tip="Add selected feat(s)"/>
                        <Button x:Name="RemoveFeatButton" Content="◀" Width="40" HorizontalContentAlignment="Center"
                                Click="OnRemoveFeatClick" ToolTip.Tip="Remove selected feat(s)"/>
                    </StackPanel>

                    <!-- Right: Selected Feats -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                            <TextBlock Text="Selected Feats" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectedFeatCountLabel" Text="(0 chosen + 0 granted)"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" Margin="0,25,0,0">
                            <ListBox x:Name="SelectedFeatsListBox" SelectionMode="Multiple,Toggle"
                                     SelectionChanged="OnSelectedFeatSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2,16,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SourceLabel}" FontSize="{DynamicResource FontSizeXSmall}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Feat Description Panel -->
                <Border Grid.Row="4" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="10" CornerRadius="4" Margin="0,8,0,0" MinHeight="60" MaxHeight="120">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="FeatDescriptionTitle" FontWeight="Bold" FontSize="{DynamicResource FontSizeSmall}"
                                       Text="Select a feat to see its description"/>
                            <TextBlock x:Name="FeatDescriptionText" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeSmall}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Step 8: Skills -->
            <Grid x:Name="Step8Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Allocate Skills" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Spend skill points on your character's abilities. Class skills cost 1 point, cross-class skills cost 2."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Points Remaining -->
                <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="12" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Skill Points Remaining:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SkillPointsRemainingLabel" Text="0" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" x:Name="SkillSearchBox" Watermark="Filter skills..."
                                 Width="160" Margin="10,0" TextChanged="OnSkillSearchChanged"/>
                        <Button Grid.Column="2" x:Name="SkillAutoAssignButton" Content="Auto-Assign" Click="OnSkillAutoAssignClick"/>
                    </Grid>
                </Border>

                <!-- Skills Grid -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="12,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Skill" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Key" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Ranks" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Max" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="Type" FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <!-- Skill Rows -->
                        <ScrollViewer Grid.Row="1">
                            <StackPanel x:Name="SkillRowsPanel" Spacing="0" Margin="0,0,15,0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Step 9: Spells -->
            <Grid x:Name="Step9Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select Spells" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" x:Name="SpellStepDescription"
                           Text="Choose spells known for your class."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Spell Level Tabs + Selection Counter + Auto-Assign -->
                <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="12" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" x:Name="SpellLevelTabsPanel" Orientation="Horizontal" Spacing="4"/>
                        <TextBlock Grid.Column="1" x:Name="SpellSelectionCountLabel" VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="10,0"/>
                        <Button Grid.Column="2" x:Name="SpellAutoAssignButton" Content="Auto-Assign" Click="OnSpellAutoAssignClick"/>
                    </Grid>
                </Border>

                <!-- Two-panel spell selection -->
                <Grid Grid.Row="3" x:Name="SpellSelectionTwoPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Available Spells -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Available Spells" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" x:Name="SpellSearchBox" Watermark="Filter spells..."
                                 Margin="0,0,0,5" TextChanged="OnSpellSearchChanged"/>
                        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1">
                            <ListBox x:Name="AvailableSpellsListBox" SelectionMode="Multiple,Toggle">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SchoolAbbrev}" FontSize="{DynamicResource FontSizeXSmall}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>

                    <!-- Center: Add/Remove Buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="AddSpellButton" Content="▶" Width="40" HorizontalContentAlignment="Center"
                                Click="OnAddSpellClick" ToolTip.Tip="Add selected spell(s)"/>
                        <Button x:Name="RemoveSpellButton" Content="◀" Width="40" HorizontalContentAlignment="Center"
                                Click="OnRemoveSpellClick" ToolTip.Tip="Remove selected spell(s)"/>
                    </StackPanel>

                    <!-- Right: Selected Spells -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,5">
                            <TextBlock Text="Selected Spells" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectedSpellCountLabel" Text="(0 / 0)"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" Margin="0,25,0,0">
                            <ListBox x:Name="SelectedSpellsListBox" SelectionMode="Multiple,Toggle">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SchoolAbbrev}" FontSize="{DynamicResource FontSizeXSmall}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Divine caster info overlay (shown instead of two-panel for divine casters) -->
                <Border Grid.Row="3" x:Name="DivineSpellInfoPanel" IsVisible="False"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock x:Name="DivineSpellInfoLabel" TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="{DynamicResource GlobalFontSize}"/>
                        <TextBlock Text="No spell selection is needed — your spells will be available automatically."
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Step 10: Starting Equipment -->
            <Grid x:Name="Step10Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Starting Equipment" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" x:Name="EquipmentStepDescription"
                           Text="Equip your character with starting gear from the package defaults, or skip to equip later."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- Equipment Actions -->
                <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="12" CornerRadius="4" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Items:" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="EquipmentCountLabel" Text="0 items" FontSize="{DynamicResource GlobalFontSize}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="LoadPackageEquipmentButton" Content="Load Package Defaults"
                                Click="OnLoadPackageEquipmentClick" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" x:Name="ClearEquipmentButton" Content="Clear All" Click="OnClearEquipmentClick"/>
                    </Grid>
                </Border>

                <!-- Equipment List -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="12,6" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Item" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Slot" FontWeight="Bold"/>
                            </Grid>
                        </Border>

                        <!-- Equipment Items -->
                        <ScrollViewer Grid.Row="1">
                            <StackPanel x:Name="EquipmentItemsPanel" Spacing="2" Margin="0,0,15,0"/>
                        </ScrollViewer>

                        <!-- Empty state message -->
                        <TextBlock x:Name="EquipmentEmptyLabel" Grid.Row="1"
                                   Text="No equipment selected. Click 'Load Package Defaults' to auto-equip, or skip this step to equip later in the editor."
                                   TextWrapping="Wrap" FontStyle="Italic"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="20"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Step 11: Summary & Create -->
            <Grid x:Name="Step11Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Review &amp; Create" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Review your choices and create your character."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="2">
                    <StackPanel Spacing="10" Margin="0,0,16,0">
                        <!-- Summary Sections -->
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1" Padding="12" CornerRadius="4">
                            <StackPanel Spacing="12">
                                <!-- File Type -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="File Type:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryFileTypeLabel"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="1" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Race & Sex -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Race &amp; Sex:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryRaceLabel"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="2" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Identity -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Identity:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryIdentityLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="3" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Appearance -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Appearance:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryAppearanceLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="4" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Class & Alignment -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Class:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryClassLabel"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="5" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="Alignment:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryAlignmentLabel"/>
                                </Grid>

                                <!-- Familiar (conditional) -->
                                <Grid ColumnDefinitions="120,*" x:Name="SummaryFamiliarSection" IsVisible="False">
                                    <TextBlock Grid.Column="0" Text="Familiar:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryFamiliarLabel" TextWrapping="Wrap"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Abilities -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Abilities:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryAbilitiesLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="6" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Feats -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Feats:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryFeatsLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="7" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Skills -->
                                <Grid ColumnDefinitions="120,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Skills:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummarySkillsLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="8" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Spells -->
                                <Grid ColumnDefinitions="120,*,Auto" x:Name="SummarySpellsSection">
                                    <TextBlock Grid.Column="0" Text="Spells:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummarySpellsLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="9" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                                <!-- Equipment -->
                                <Grid ColumnDefinitions="120,*,Auto" x:Name="SummaryEquipmentSection">
                                    <TextBlock Grid.Column="0" Text="Equipment:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryEquipmentLabel" TextWrapping="Wrap"/>
                                    <Button Grid.Column="2" Content="[Edit]" Classes="hyperlink"
                                            Tag="10" Click="OnSummaryEditClick" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="2"
                                            Foreground="{DynamicResource SystemAccentColor}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        x:Name="SummaryScriptsDivider"/>

                                <!-- Scripts (UTC only) -->
                                <Grid ColumnDefinitions="120,*" x:Name="SummaryScriptsSection">
                                    <TextBlock Grid.Column="0" Text="Scripts:" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="SummaryScriptsLabel" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>

        <!-- Bottom Button Bar -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message -->
                <TextBlock Grid.Column="0" x:Name="StatusLabel"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="BackButton" Content="Back" Width="80" Click="OnBackClick" IsEnabled="False"/>
                    <Button x:Name="NextButton" Content="Next" Width="80" Click="OnNextClick"/>
                    <Button x:Name="FinishButton" Content="Create" Width="80" Click="OnFinishClick" IsVisible="False"/>
                    <Button Content="Cancel" Width="80" Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
