<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Quartermaster.Views.Dialogs.LevelUpWizardWindow"
        Title="Level Up Wizard"
        AutomationProperties.AutomationId="LevelUpWizardWindow"
        MinWidth="900" MinHeight="600"
        Width="1000" Height="700"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackground}">

    <Window.Styles>
        <!-- Dark mode selection visibility fix -->
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Step indicator styles -->
        <Style Selector="Border.step-indicator">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Border.step-indicator.current">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
        </Style>
        <Style Selector="Border.step-indicator.completed">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left Sidebar: Step Navigator -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="10">
            <StackPanel>
                <!-- Character Info Header -->
                <TextBlock x:Name="CharacterNameLabel"
                           Text="Character Name"
                           FontSize="{DynamicResource FontSizeMedium}"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="CharacterLevelLabel"
                           Text="Level X -> Y"
                           FontSize="{DynamicResource FontSizeSmall}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,0,0,20"/>

                <!-- Step Indicators -->
                <TextBlock Text="Steps" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Border x:Name="Step1Border" Classes="step-indicator current">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step1Number" Text="1" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Select Class"/>
                        </StackPanel>
                        <TextBlock x:Name="Step1Summary" Text=""
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="30,2,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step2Border" Classes="step-indicator">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step2Number" Text="2" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Ability Score"/>
                        </StackPanel>
                        <TextBlock x:Name="Step2Summary" Text=""
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="30,2,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step3Border" Classes="step-indicator">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step3Number" Text="3" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Select Feats"/>
                        </StackPanel>
                        <TextBlock x:Name="Step3Summary" Text=""
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="30,2,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step4Border" Classes="step-indicator">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step4Number" Text="4" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Allocate Skills"/>
                        </StackPanel>
                        <TextBlock x:Name="Step4Summary" Text=""
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="30,2,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step5Border" Classes="step-indicator">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step5Number" Text="5" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Select Spells"/>
                        </StackPanel>
                        <TextBlock x:Name="Step5Summary" Text=""
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="30,2,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="Step6Border" Classes="step-indicator">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock x:Name="Step6Number" Text="6" FontWeight="Bold" Width="20"/>
                            <TextBlock Text="Summary"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Validation Level Toggle (#1503, simplified #1882) -->
                <Separator Margin="0,15,0,10"/>
                <TextBlock Text="Validation Level" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ValidationLevelComboBox"
                          AutomationProperties.AutomationId="ValidationLevelComboBox"
                          HorizontalAlignment="Stretch"
                          SelectedIndex="0">
                    <ComboBoxItem Content="😈 Chaotic Evil" ToolTip.Tip="No validation. Anything goes — for power users and custom content."/>
                    <ComboBoxItem Content="⚔️ Lawful Good" ToolTip.Tip="Enforce ELC rules. Block invalid selections."/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="15">
            <!-- Step 1: Class Selection -->
            <Grid x:Name="Step1Panel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select Class" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Class List -->
                    <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" x:Name="ClassSearchBox"
                                     Watermark="Filter classes..."
                                     Margin="0,0,0,5"
                                     TextChanged="OnClassSearchChanged"/>

                            <CheckBox Grid.Row="1" x:Name="ShowUnqualifiedPrestigeCheckBox"
                                      Content="Show unqualified prestige"
                                      IsChecked="True"
                                      Margin="0,0,0,5"
                                      Checked="OnClassFilterChanged"
                                      Unchecked="OnClassFilterChanged"/>

                            <ListBox Grid.Row="2" x:Name="ClassListBox"
                                     SelectionChanged="OnClassSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="{Binding Icon}" Width="16"/>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                            <TextBlock Text="{Binding Badge}"
                                                       Foreground="{DynamicResource ThemeWarning}"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Class Details -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" x:Name="SelectedClassNameLabel"
                                       Text="Select a class"
                                       FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1" x:Name="ClassStatsPanel" Orientation="Horizontal" Spacing="20" Margin="0,0,0,10" IsVisible="False">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Hit Die:" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ClassHitDieLabel"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Skills:" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ClassSkillPointsLabel"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Levels:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <NumericUpDown x:Name="LevelsToAddSpinner"
                                                   Value="1" Minimum="1" Maximum="39"
                                                   Width="100" Height="28"
                                                   FormatString="0"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Prerequisites Panel -->
                            <Border Grid.Row="2" x:Name="ClassPrereqPanel"
                                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    Padding="10" Margin="0,0,0,10" IsVisible="False">
                                <StackPanel>
                                    <TextBlock Text="Prerequisites" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <ItemsControl x:Name="ClassPrereqItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2">
                                                    <TextBlock Text="{Binding Icon}" Width="25"/>
                                                    <TextBlock Text="{Binding Text}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="3">
                                <TextBlock x:Name="ClassDescriptionLabel"
                                           TextWrapping="Wrap"
                                           Text="Select a class to see its description."
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Step 2: Ability Score Increase (every 4th level) -->
            <Grid x:Name="Step2Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Ability Score Increase" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" x:Name="AbilityIncreaseDescription"
                           Text="Choose one ability score to increase by +1."
                           Margin="0,0,0,5"/>
                <TextBlock Grid.Row="2" x:Name="AbilityIncreaseRemaining"
                           Text="Remaining: 0"
                           FontWeight="Bold" Margin="0,0,0,10"/>

                <Border Grid.Row="3" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                        <Border x:Name="AbilityStrBorder" Classes="step-indicator" Tag="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Strength" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityStrValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="0" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityStrRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="0" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityStrChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <Border x:Name="AbilityDexBorder" Classes="step-indicator" Tag="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Dexterity" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityDexValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="1" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityDexRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="1" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityDexChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <Border x:Name="AbilityConBorder" Classes="step-indicator" Tag="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Constitution" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityConValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="2" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityConRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="2" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityConChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <Border x:Name="AbilityIntBorder" Classes="step-indicator" Tag="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Intelligence" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityIntValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="3" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityIntRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="3" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityIntChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <Border x:Name="AbilityWisBorder" Classes="step-indicator" Tag="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wisdom" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityWisValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="4" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityWisRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="4" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityWisChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <Border x:Name="AbilityChaBorder" Classes="step-indicator" Tag="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Charisma" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="AbilityChaValue" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="-" Tag="5" Click="OnAbilityDecrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="3" x:Name="AbilityChaRadio" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="4" Content="+" Tag="5" Click="OnAbilityIncrease" Width="28" Height="28" HorizontalContentAlignment="Center" Padding="0"/>
                                <TextBlock Grid.Column="5" x:Name="AbilityChaChange" Text="" Foreground="{DynamicResource ThemeSuccess}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Step 3: Feat Selection (shown when applicable) -->
            <Grid x:Name="Step3Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select Feats" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" x:Name="FeatAllocationLabel"
                           Text="You have 1 feat to select."
                           Margin="0,0,0,15"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Available Feats -->
                    <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5" Margin="0,0,5,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Available Feats" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Grid.Row="1" x:Name="FeatSearchBox"
                                     Watermark="Filter feats..."
                                     Margin="0,0,0,5"
                                     TextChanged="OnFeatSearchChanged"/>
                            <ListBox Grid.Row="2" x:Name="AvailableFeatsListBox"
                                     SelectionChanged="OnAvailableFeatSelected"
                                     DoubleTapped="OnFeatDoubleClicked">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" ToolTip.Tip="{Binding PrereqTooltip}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                            <TextBlock Text="{Binding Badge}"
                                                       Margin="5,0,0,0"
                                                       Foreground="{DynamicResource ThemeWarning}"
                                                       IsVisible="{Binding Badge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Selected Feats -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5" Margin="5,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" x:Name="SelectedFeatsHeader" Text="Selected Feats (0/1)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ListBox Grid.Row="1" x:Name="SelectedFeatsListBox"
                                     DoubleTapped="OnSelectedFeatDoubleClicked"
                                     SelectionChanged="OnSelectedFeatSelectionChanged"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                                <Button x:Name="AddFeatButton" Content="Add" Click="OnAddFeatClick" IsEnabled="False"/>
                                <Button x:Name="RemoveFeatButton" Content="Remove" Click="OnRemoveFeatClick" IsEnabled="False"/>
                                <Button x:Name="FeatAutoAssignButton" Content="Auto-Assign" Click="OnFeatAutoAssignClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Feat Description -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="8" Margin="0,5,0,0"
                        MaxHeight="120">
                    <ScrollViewer>
                        <TextBlock x:Name="FeatDescriptionLabel"
                                   Text="Select a feat to see its description."
                                   TextWrapping="Wrap"
                                   Margin="0,0,12,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Step 4: Skill Allocation -->
            <Grid x:Name="Step4Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Allocate Skill Points" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20" Margin="0,0,0,15">
                    <TextBlock x:Name="SkillPointsRemainingLabel" Text="Points remaining: 5" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SkillPointsTotalLabel" Text="(Base 2 + INT 3 = 5)" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="SkillAutoAssignButton" Content="Auto-Assign" Click="OnSkillAutoAssignClick"/>
                    <TextBox x:Name="SkillSearchBox" Watermark="Filter skills..." Width="160" TextChanged="OnSkillSearchChanged"/>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5">
                    <ScrollViewer>
                        <ItemsControl x:Name="SkillsItemsControl" Margin="0,0,15,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,3" Opacity="{Binding RowOpacity}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{Binding NameBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CurrentRanks}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="-" Width="25" Click="OnSkillDecrease" Tag="{Binding SkillId}" IsEnabled="{Binding CanDecrease}"/>
                                        <Button Grid.Column="3" Content="+" Width="25" Click="OnSkillIncrease" Tag="{Binding SkillId}" IsEnabled="{Binding CanIncrease}"/>
                                        <TextBlock Grid.Column="4" Text="{Binding AddedRanks}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ThemeSuccess}"/>
                                        <TextBlock Grid.Column="5" Text="{Binding ClassSkillIndicator}" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Step 5: Spell Selection (for casters) -->
            <Grid x:Name="Step5Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select Spells" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" x:Name="SpellStepDescription"
                           Text="Select new spells to learn."
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <!-- Spell level tabs + count + auto-assign -->
                <Border Grid.Row="2" x:Name="SpellTabsBar"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="5" Margin="0,0,0,10" IsVisible="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" x:Name="SpellLevelTabsPanel" Orientation="Horizontal"/>
                        <TextBlock Grid.Column="1" x:Name="SpellSelectionCountLabel" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="10,0"/>
                        <Button Grid.Column="2" x:Name="SpellAutoAssignButton" Content="Auto-Assign"
                                Click="OnSpellAutoAssignClick"/>
                    </Grid>
                </Border>

                <!-- Spell selection two-panel (for arcane/spontaneous casters) -->
                <Grid Grid.Row="3" x:Name="SpellSelectionTwoPanel" IsVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Available Spells -->
                    <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Available Spells" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox Grid.Row="1" x:Name="SpellSearchBox"
                                     Watermark="Filter spells..."
                                     Margin="0,0,0,5"
                                     TextChanged="OnSpellSearchChanged"/>
                            <ListBox Grid.Row="2" x:Name="AvailableSpellsListBox"
                                     SelectionMode="Multiple,Toggle">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SchoolAbbrev}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       FontSize="{DynamicResource FontSizeSmall}" Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Add/Remove buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                        <Button x:Name="AddSpellButton" Content="+" Width="40" Click="OnAddSpellClick"/>
                        <Button x:Name="RemoveSpellButton" Content="-" Width="40" Click="OnRemoveSpellClick"/>
                    </StackPanel>

                    <!-- Selected Spells -->
                    <Border Grid.Column="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5" Margin="0,0,0,5">
                                <TextBlock Text="Selected Spells" FontWeight="Bold"/>
                                <TextBlock x:Name="SelectedSpellCountLabel" Text="(0 / 0)"/>
                            </StackPanel>
                            <ListBox Grid.Row="1" x:Name="SelectedSpellsListBox"
                                     SelectionMode="Multiple,Toggle">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SchoolAbbrev}"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       FontSize="{DynamicResource FontSizeSmall}" Margin="5,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Divine caster info panel (for Cleric/Druid/Ranger/Paladin) -->
                <Border Grid.Row="3" x:Name="DivineSpellInfoPanel" IsVisible="False"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        Padding="20" CornerRadius="4"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Spacing="10">
                        <TextBlock x:Name="DivineSpellInfoLabel"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <ItemsControl x:Name="DivineSpellsList" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Step 6: Summary -->
            <Grid x:Name="Step6Panel" IsVisible="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Level Up Summary" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="Bold" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1">
                    <StackPanel x:Name="SummaryPanel" Spacing="15" Margin="0,0,15,0">
                        <!-- Class Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Class" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="SummaryClassLabel" Text="Fighter 5 -> 6"/>
                            </StackPanel>
                        </Border>

                        <!-- Ability Score Section -->
                        <Border x:Name="SummaryAbilityPanel" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4" IsVisible="False">
                            <StackPanel>
                                <TextBlock Text="Ability Score Increase" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <TextBlock x:Name="SummaryAbilityLabel" Text="Strength 14 -> 15"/>
                            </StackPanel>
                        </Border>

                        <!-- Feats Section -->
                        <Border x:Name="SummaryFeatsPanel" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4" IsVisible="False">
                            <StackPanel>
                                <TextBlock Text="New Feats" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <ItemsControl x:Name="SummaryFeatsList"/>
                            </StackPanel>
                        </Border>

                        <!-- Skills Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Skill Points Allocated" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <ItemsControl x:Name="SummarySkillsList"/>
                            </StackPanel>
                        </Border>

                        <!-- Spells Section -->
                        <Border x:Name="SummarySpellsPanel" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4" IsVisible="False">
                            <StackPanel>
                                <TextBlock Text="New Spells" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <ItemsControl x:Name="SummarySpellsList"/>
                            </StackPanel>
                        </Border>

                        <!-- Stats Changes -->
                        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="15" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Derived Stats" FontWeight="Bold" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="HP" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SummaryHpLabel" Text="+d10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="BAB" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SummaryBabLabel" Text="+1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Saves" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="SummarySavesLabel" Text="Fort +1"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Bottom Button Bar -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Message -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="StatusLabel"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="PrestigeHintsLabel"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap"
                               IsVisible="False"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="BackButton" Content="Back" Width="80" Click="OnBackClick" IsEnabled="False"/>
                    <Button x:Name="NextButton" Content="Next" Width="80" Click="OnNextClick"/>
                    <Button x:Name="FinishButton" Content="Finish" Width="80" Click="OnFinishClick" IsVisible="False"/>
                    <Button Content="Cancel" Width="80" Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
