<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Quartermaster.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Quartermaster.Views.Panels.AppearancePanel">

    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
        <!-- Main split: Left (body parts) / Right (3D preview) -->
        <Grid ColumnDefinitions="350,*">

            <!-- LEFT PANEL: Body Parts Configuration -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15" Margin="15,15,30,15">
                    <!-- Header -->
                    <TextBlock Text="Appearance"
                               FontSize="{DynamicResource FontSizeLarge}"
                               FontWeight="Bold"/>

                    <!-- Model Selection Section -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Model" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeNormal}"/>

                            <!-- Search Box -->
                            <TextBox x:Name="AppearanceSearchBox"
                                     Watermark="Search appearances..."
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     AutomationProperties.AutomationId="AppearanceSearchBox"/>

                            <!-- Source Filters -->
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
                                <CheckBox x:Name="ShowBifCheckBox" Content="Standard"
                                          IsChecked="True" FontSize="{DynamicResource FontSizeXSmall}"
                                          AutomationProperties.AutomationId="ShowBifCheckBox"
                                          ToolTip.Tip="Show base game models from BIF archives"/>
                                <CheckBox x:Name="ShowHakCheckBox" Content="Hak"
                                          IsChecked="True" FontSize="{DynamicResource FontSizeXSmall}"
                                          AutomationProperties.AutomationId="ShowHakCheckBox"
                                          ToolTip.Tip="Show models from loaded HAK packs"/>
                                <CheckBox x:Name="ShowOverrideCheckBox" Content="Override"
                                          IsChecked="True" FontSize="{DynamicResource FontSizeXSmall}"
                                          AutomationProperties.AutomationId="ShowOverrideCheckBox"
                                          ToolTip.Tip="Show models from the Override directory"/>
                                <TextBlock x:Name="AppearanceCountText" Text=""
                                           FontSize="{DynamicResource FontSizeXSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Exclude Patterns -->
                            <TextBox x:Name="ExcludePatternBox"
                                     Watermark="Exclude patterns (semicolon-separated)"
                                     FontSize="{DynamicResource FontSizeXSmall}"
                                     AutomationProperties.AutomationId="ExcludePatternBox"
                                     ToolTip.Tip="Hide entries matching these patterns (e.g. Invisible;object). Matches Name and Label, case-insensitive."/>

                            <!-- Appearance List (replaces ComboBox for searchability) -->
                            <ListBox x:Name="AppearanceListBox"
                                     MaxHeight="150"
                                     FontSize="{DynamicResource FontSizeSmall}"
                                     AutomationProperties.AutomationId="AppearanceListBox"/>

                            <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="10">
                                <!-- Gender -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gender:"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="GenderComboBox"
                                          HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeSmall}"
                                          AutomationProperties.AutomationId="GenderComboBox"/>

                                <!-- Phenotype -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Phenotype:"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center" FontSize="{DynamicResource FontSizeSmall}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="PhenotypeComboBox"
                                          HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeSmall}"
                                          AutomationProperties.AutomationId="PhenotypeComboBox"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Body Parts Section -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            x:Name="BodyPartsSection">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Body Parts" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeNormal}"/>
                                <TextBlock x:Name="BodyPartsStatusText" Text="(Dynamic)"
                                           FontSize="{DynamicResource FontSizeSmall}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>

                            <StackPanel x:Name="BodyPartsContent" Spacing="8">
                                <!-- Core body parts - compact 2-column layout -->
                                <Grid ColumnDefinitions="55,80,55,80" RowDefinitions="Auto,Auto,Auto,Auto"
                                      RowSpacing="4" ColumnSpacing="6">
                                    <!-- Row 0: Head / Neck -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Head:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="HeadComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Neck:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="3" x:Name="NeckComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Row 1: Torso / Pelvis -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Torso:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TorsoComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Pelvis:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="3" x:Name="PelvisComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Row 2: Belt / Tail -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Belt:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="BeltComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Tail:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="3" x:Name="TailComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Row 3: Wings (spans 2 cols) -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Wings:" FontSize="{DynamicResource FontSizeSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="WingsComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                </Grid>

                                <!-- Limbs Section -->
                                <TextBlock Text="Limbs" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeSmall}" Margin="0,6,0,2"/>
                                <Grid ColumnDefinitions="55,80,55,80" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      RowSpacing="4" ColumnSpacing="6">

                                    <!-- Shoulders -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="L Shoul:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LShoulComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="R Shoul:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="3" x:Name="RShoulComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Biceps -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="L Bicep:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LBicepComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="R Bicep:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="3" x:Name="RBicepComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Forearms -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="L FArm:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="LFArmComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="R FArm:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="3" x:Name="RFArmComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Hands -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="L Hand:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="LHandComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="R Hand:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="3" Grid.Column="3" x:Name="RHandComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Thighs -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="L Thigh:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="LThighComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="R Thigh:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="3" x:Name="RThighComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Shins -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="L Shin:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="1" x:Name="LShinComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="5" Grid.Column="2" Text="R Shin:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="3" x:Name="RShinComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>

                                    <!-- Feet -->
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="L Foot:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="6" Grid.Column="1" x:Name="LFootComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                    <TextBlock Grid.Row="6" Grid.Column="2" Text="R Foot:" FontSize="{DynamicResource FontSizeXSmall}"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="6" Grid.Column="3" x:Name="RFootComboBox"
                                              HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeXSmall}" Padding="4,2"/>
                                </Grid>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Colors Section - separate from Body Parts so it's always enabled -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Colors" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeNormal}"/>
                            <Grid ColumnDefinitions="55,22,20,55,22" RowDefinitions="Auto,Auto" RowSpacing="4" ColumnSpacing="4">
                                <!-- Skin / Hair -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Skin:" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="1" x:Name="SkinColorSwatch" Width="18" Height="18"
                                        CornerRadius="2" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Click to choose skin color"/>

                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Hair:" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Row="0" Grid.Column="4" x:Name="HairColorSwatch" Width="18" Height="18"
                                        CornerRadius="2" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Click to choose hair color"/>

                                <!-- Tattoo 1 / Tattoo 2 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tat 1:" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="Tattoo colors apply to pixels painted in body part textures. Most base game models have minimal tattoo areas."/>
                                <Border Grid.Row="1" Grid.Column="1" x:Name="Tattoo1ColorSwatch" Width="18" Height="18"
                                        CornerRadius="2" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Click to choose tattoo 1 color"/>

                                <TextBlock Grid.Row="1" Grid.Column="3" Text="Tat 2:" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="Tattoo colors apply to pixels painted in body part textures. Custom content may add more tattoo areas."/>
                                <Border Grid.Row="1" Grid.Column="4" x:Name="Tattoo2ColorSwatch" Width="18" Height="18"
                                        CornerRadius="2" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Click to choose tattoo 2 color"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL: 3D Model Preview -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1,0,0,0"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
                    <!-- Preview Header -->
                    <Border Grid.Row="0" Padding="10"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Model Preview" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeNormal}"/>
                    </Border>

                    <!-- 3D Preview Area -->
                    <Border Grid.Row="1" x:Name="ModelPreviewContainer"
                            Background="{DynamicResource ThemeSidebar}" Margin="10" CornerRadius="4">
                        <Grid>
                            <controls:ModelPreviewGLControl x:Name="ModelPreviewGL"/>
                            <!-- Transparent input surface so pointer/wheel events always hit-test
                                 (OpenGlControlBase has no Background). #2124 -->
                            <Border x:Name="ModelPreviewInputSurface"
                                    Background="Transparent"
                                    Focusable="True"/>
                            <Border x:Name="PreviewStateOverlay"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,8,8,0"
                                    Background="#AA000000"
                                    CornerRadius="3"
                                    Padding="8,4"
                                    IsVisible="False">
                                <TextBlock x:Name="PreviewStateText"
                                           FontStyle="Italic"
                                           FontSize="12"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Model Info Status Line (#1873) -->
                    <TextBlock Grid.Row="2" x:Name="ModelInfoStatusText"
                               FontSize="{DynamicResource FontSizeSmall}" Padding="10,4"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               IsVisible="False"/>

                    <!-- Preview Controls -->
                    <Border Grid.Row="3" Padding="10"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Button x:Name="RotateLeftButton" Content="↺" Width="32" Height="32"
                                    ToolTip.Tip="Rotate Left"/>
                            <Button x:Name="ResetViewButton" Content="⟲" Width="32" Height="32"
                                    ToolTip.Tip="Reset View (Home)"/>
                            <Button x:Name="RotateRightButton" Content="↻" Width="32" Height="32"
                                    ToolTip.Tip="Rotate Right"/>
                            <Button x:Name="ZoomInButton" Content="+" Width="32" Height="32"
                                    ToolTip.Tip="Zoom In" Margin="20,0,0,0"/>
                            <Button x:Name="ZoomOutButton" Content="-" Width="32" Height="32"
                                    ToolTip.Tip="Zoom Out"/>
                            <!-- View preset buttons (#2124) -->
                            <Button x:Name="ViewFrontButton" Content="F" Width="32" Height="32"
                                    ToolTip.Tip="Front View" Margin="20,0,0,0"/>
                            <Button x:Name="ViewBackButton" Content="B" Width="32" Height="32"
                                    ToolTip.Tip="Back View"/>
                            <Button x:Name="ViewSideButton" Content="L" Width="32" Height="32"
                                    ToolTip.Tip="Left Side View"/>
                            <Button x:Name="ViewSideRightButton" Content="R" Width="32" Height="32"
                                    ToolTip.Tip="Right Side View"/>
                            <Button x:Name="ViewTopButton" Content="T" Width="32" Height="32"
                                    ToolTip.Tip="Top View"/>
                        </StackPanel>
                    </Border>

                    <!-- Animation playback (#2124) -->
                    <Border Grid.Row="4" Padding="10"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="Animation:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AnimationComboBox" MinWidth="160"
                                      ToolTip.Tip="Select an animation / stance"/>
                            <Button x:Name="AnimPlayButton" Content="▶" Width="32" Height="32"
                                    ToolTip.Tip="Play / Pause"/>
                            <Slider x:Name="AnimTimeSlider" MinWidth="160"
                                    Minimum="0" Maximum="1" Value="0"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Scrub playhead"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
