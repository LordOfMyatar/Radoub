<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Radoub.UI.Controls"
        xmlns:radoubControls="using:Radoub.UI.Controls"
        xmlns:converters="using:MerchantEditor.Converters"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="MerchantEditor.Views.MainWindow"
        x:Name="MainWindowInstance"
        Title="Fence - Merchant Editor"
        Icon="avares://Fence/Assets/fence.ico"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="30"
        KeyDown="OnWindowKeyDown">

    <Window.Resources>
        <converters:InfiniteToSymbolConverter x:Key="InfiniteToSymbolConverter"/>
    </Window.Resources>

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ThemeTitleBar}"
                Height="30"
                x:Name="TitleBar"
                PointerPressed="OnTitleBarPointerPressed"
                DoubleTapped="OnTitleBarDoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="avares://Fence/Assets/fence.ico"
                       Width="{DynamicResource GlobalFontSize}"
                       Height="{DynamicResource GlobalFontSize}"
                       Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeTitleBarForeground}"/>
            </StackPanel>
        </Border>

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" AutomationProperties.AutomationId="MainMenu">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="OnNewClick" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Open..." Click="OnOpenClick" InputGesture="Ctrl+O"/>
                <MenuItem Header="Open _Recent" x:Name="RecentFilesMenu"/>
                <Separator/>
                <MenuItem Header="_Save" Click="OnSaveClick" InputGesture="Ctrl+S" IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <MenuItem Header="Save _As..." Click="OnSaveAsClick" InputGesture="Ctrl+Shift+S" IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <Separator/>
                <MenuItem Header="_Close" Click="OnCloseFileClick" IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <MenuItem Header="E_xit" Click="OnExitClick" InputGesture="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z" IsEnabled="False" ToolTip.Tip="Not yet implemented"/>
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y" IsEnabled="False" ToolTip.Tip="Not yet implemented"/>
                <Separator/>
                <MenuItem Header="_Delete Selected" Click="OnDeleteClick" InputGesture="Delete" IsEnabled="{Binding HasSelection, ElementName=MainWindowInstance}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="StoreBrowserMenuItem" Header="_Store Browser" Click="OnToggleStoreBrowserClick" InputGesture="F4"/>
                <MenuItem x:Name="ItemDetailsPanelMenuItem" Header="_Item Details" Click="OnToggleItemDetailsPanelClick" InputGesture="F5"/>
                <Separator/>
                <MenuItem x:Name="LanguageMenu" Header="_Language" AutomationProperties.AutomationId="LanguageMenu"/>
                <Separator/>
                <MenuItem Header="_Settings..." Click="OnSettingsClick"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Fence" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar (top position for visibility during loading) -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                Margin="8,4,8,0"
                AutomationProperties.AutomationId="StatusBar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ModuleText" Grid.Column="0" Text="No module selected" FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Grid.Column="1" Text="Ready" Margin="20,0,0,0" AutomationProperties.AutomationId="StatusText"/>
                <TextBlock x:Name="ItemCountText" Grid.Column="2" Text="" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="20,0,0,0"/>
                <TextBlock x:Name="FilePathText" Grid.Column="3" Text="" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <!-- Main Content Area with Store Browser Panel -->
        <Grid x:Name="OuterContentGrid" Margin="8">
            <Grid.ColumnDefinitions>
                <!-- Store browser panel (#1144) - collapsible left panel -->
                <ColumnDefinition Width="200" MinWidth="0"/>
                <ColumnDefinition Width="5"/>
                <!-- Main content area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Store Browser Panel (#1144) -->
            <radoubControls:StoreBrowserPanel x:Name="StoreBrowserPanel"
                                              Grid.Column="0"
                                              Margin="0,0,0,0"/>

            <!-- Store Browser Splitter -->
            <GridSplitter x:Name="StoreBrowserSplitter"
                          Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                          AutomationProperties.AutomationId="StoreBrowserSplitter"/>

            <!-- Inner grid for main content -->
            <Grid Grid.Column="2" x:Name="MainGrid">
                <Grid.RowDefinitions>
                    <!-- Store Properties -->
                    <RowDefinition Height="Auto"/>
                    <!-- Collapsible panels (side by side) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Inventory and Palette -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <!-- Store Properties Panel -->
            <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                    AutomationProperties.AutomationId="StorePropertiesPanel">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Name, Tag, ResRef, Category -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <controls:SpellCheckTextBox Grid.Row="0" Grid.Column="1" x:Name="StoreNameBox" AutomationProperties.AutomationId="StoreNameBox"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Tag:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="StoreTagBox" AutomationProperties.AutomationId="StoreTagBox"/>

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="ResRef:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Grid Grid.Row="0" Grid.Column="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="StoreResRefBox" IsReadOnly="True" AutomationProperties.AutomationId="StoreResRefBox"
                                 ToolTip.Tip="Read-only. Click Rename to change."/>
                        <Button Grid.Column="1" x:Name="RenameResRefButton" Content="Rename" Padding="8,2" Margin="5,0,0,0"
                                FontSize="{DynamicResource FontSizeSmall}"
                                Click="OnRenameResRefClick"
                                AutomationProperties.AutomationId="RenameResRefButton"
                                ToolTip.Tip="Rename file and update ResRef"/>
                    </Grid>

                    <TextBlock Grid.Row="0" Grid.Column="9" Text="Category:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="10" x:Name="StoreCategoryBox" MinWidth="150" AutomationProperties.AutomationId="StoreCategoryBox"/>

                    <!-- Row 1: Pricing -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Sell Markup %:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="SellMarkupBox" Margin="0,8,0,0" AutomationProperties.AutomationId="SellMarkupBox"/>

                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Buy Markdown %:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="BuyMarkdownBox" Margin="0,8,0,0" AutomationProperties.AutomationId="BuyMarkdownBox"/>

                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Identify Price:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <TextBox Grid.Row="1" Grid.Column="7" x:Name="IdentifyPriceBox" Margin="0,8,0,0" AutomationProperties.AutomationId="IdentifyPriceBox"/>

                    <!-- Row 2: Scripts and Store Options -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="OnOpenStore:" VerticalAlignment="Center" Margin="0,8,8,0"/>
                    <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="OnOpenStoreBox" MaxLength="16" FontFamily="Consolas" Watermark="(none)"
                                 AutomationProperties.AutomationId="OnOpenStoreBox"/>
                        <Button Grid.Column="1" Content="..." Width="38" Margin="4,0,0,0" Click="OnBrowseOpenScript"
                                ToolTip.Tip="Browse for script" AutomationProperties.AutomationId="BrowseOpenScriptButton"/>
                        <Button Grid.Column="2" Content="✕" Width="38" Margin="4,0,0,0" Click="OnClearOpenScript"
                                ToolTip.Tip="Clear script" AutomationProperties.AutomationId="ClearOpenScriptButton"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="OnStoreClosed:" VerticalAlignment="Center" Margin="8,8,8,0"/>
                    <Grid Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="OnStoreClosedBox" MaxLength="16" FontFamily="Consolas" Watermark="(none)"
                                 AutomationProperties.AutomationId="OnStoreClosedBox"/>
                        <Button Grid.Column="1" Content="..." Width="38" Margin="4,0,0,0" Click="OnBrowseClosedScript"
                                ToolTip.Tip="Browse for script" AutomationProperties.AutomationId="BrowseClosedScriptButton"/>
                        <Button Grid.Column="2" Content="✕" Width="38" Margin="4,0,0,0" Click="OnClearClosedScript"
                                ToolTip.Tip="Clear script" AutomationProperties.AutomationId="ClearClosedScriptButton"/>
                    </Grid>

                    <!-- Max Buy Price and Limited Gold on same row as scripts -->
                    <StackPanel Grid.Row="2" Grid.Column="6" Grid.ColumnSpan="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,8,0,0">
                        <CheckBox x:Name="MaxBuyPriceCheck" Content="Max Buy Price:" Margin="0,0,8,0" AutomationProperties.AutomationId="MaxBuyPriceCheck"/>
                        <TextBox x:Name="MaxBuyPriceBox" Width="80" IsEnabled="{Binding IsChecked, ElementName=MaxBuyPriceCheck}" AutomationProperties.AutomationId="MaxBuyPriceBox"/>
                        <CheckBox x:Name="LimitedGoldCheck" Content="Limited Gold:" Margin="16,0,8,0" AutomationProperties.AutomationId="LimitedGoldCheck"/>
                        <TextBox x:Name="StoreGoldBox" Width="80" IsEnabled="{Binding IsChecked, ElementName=LimitedGoldCheck}" AutomationProperties.AutomationId="StoreGoldBox"/>
                    </StackPanel>

                    <!-- Row 3: Comment (full width at bottom) -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Comment:" VerticalAlignment="Top" Margin="0,8,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="10" x:Name="CommentBox"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="50" Margin="0,8,0,0"
                             Watermark="Developer notes..."
                             AutomationProperties.AutomationId="CommentBox"/>
                </Grid>
            </Border>

            <!-- Collapsible Panels (side by side) -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Buy Restrictions Panel -->
                <Expander Grid.Column="0" Header="Buy Restrictions" IsExpanded="False"
                          AutomationProperties.AutomationId="BuyRestrictionsExpander">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                        <StackPanel Spacing="8">
                            <!-- Buy Stolen Goods (moved from Store Properties) -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox x:Name="BlackMarketCheck" Content="Buy Stolen Goods" AutomationProperties.AutomationId="BlackMarketCheck"/>
                                <TextBlock Text="Markdown:" VerticalAlignment="Center" IsVisible="{Binding IsChecked, ElementName=BlackMarketCheck}"/>
                                <TextBox x:Name="BlackMarketMarkdownBox" Width="50" IsVisible="{Binding IsChecked, ElementName=BlackMarketCheck}" AutomationProperties.AutomationId="BlackMarketMarkdownBox"/>
                                <TextBlock Text="%" VerticalAlignment="Center" IsVisible="{Binding IsChecked, ElementName=BlackMarketCheck}"/>
                            </StackPanel>

                            <Separator Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="0,4"/>

                            <!-- Mode Selection -->
                            <StackPanel Spacing="4">
                                <RadioButton x:Name="BuyAllRadio" Content="Buy All Item Types" GroupName="BuyMode" IsChecked="True"
                                             Checked="OnBuyModeChanged" AutomationProperties.AutomationId="BuyAllRadio"/>
                                <RadioButton x:Name="WillOnlyBuyRadio" Content="Will Only Buy Selected" GroupName="BuyMode"
                                             Checked="OnBuyModeChanged" AutomationProperties.AutomationId="WillOnlyBuyRadio"/>
                                <RadioButton x:Name="WillNotBuyRadio" Content="Will Not Buy Selected" GroupName="BuyMode"
                                             Checked="OnBuyModeChanged" AutomationProperties.AutomationId="WillNotBuyRadio"/>
                            </StackPanel>

                            <!-- Helper Buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        IsVisible="{Binding !IsChecked, ElementName=BuyAllRadio}">
                                <Button Content="Select All" Click="OnSelectAllTypes" AutomationProperties.AutomationId="SelectAllTypesButton"/>
                                <Button Content="Clear All" Click="OnClearAllTypes" AutomationProperties.AutomationId="ClearAllTypesButton"/>
                            </StackPanel>

                            <!-- Item Type Checkboxes -->
                            <ScrollViewer MaxHeight="150" IsVisible="{Binding !IsChecked, ElementName=BuyAllRadio}">
                                <ItemsControl x:Name="ItemTypeCheckboxes" AutomationProperties.AutomationId="ItemTypeCheckboxes">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsSelected}"
                                                      Width="140" Margin="0,2,4,2"
                                                      Checked="OnItemTypeCheckChanged"
                                                      Unchecked="OnItemTypeCheckChanged"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- Local Variables Panel -->
                <Expander Grid.Column="2" Header="Local Variables" IsExpanded="False"
                          AutomationProperties.AutomationId="VariablesExpander">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                        <DockPanel>
                            <!-- Action Buttons -->
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Content="Add" Click="OnAddVariable" AutomationProperties.AutomationId="AddVariableButton"/>
                                <Button Content="Remove" Click="OnRemoveVariable" AutomationProperties.AutomationId="RemoveVariableButton"/>
                            </StackPanel>

                            <!-- Variables DataGrid -->
                            <DataGrid x:Name="VariablesGrid"
                                      AutoGenerateColumns="False"
                                      CanUserReorderColumns="True"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="True"
                                      IsReadOnly="False"
                                      SelectionMode="Extended"
                                      GridLinesVisibility="Horizontal"
                                      MaxHeight="180"
                                      AutomationProperties.AutomationId="VariablesGrid">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="120" Binding="{Binding Name}"/>
                                    <DataGridTemplateColumn Header="Type" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TypeDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedIndex="{Binding TypeIndex}" Margin="0">
                                                    <ComboBoxItem Content="Int"/>
                                                    <ComboBoxItem Content="Float"/>
                                                    <ComboBoxItem Content="String"/>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Value" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ValueDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <NumericUpDown Value="{Binding IntValue}" IsVisible="{Binding IsIntType}" Minimum="-2147483648" Maximum="2147483647"/>
                                                    <NumericUpDown Value="{Binding FloatValue}" IsVisible="{Binding IsFloatType}" Increment="0.001" FormatString="F3"/>
                                                    <TextBox Text="{Binding StringValue}" IsVisible="{Binding IsStringType}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Expander>
            </Grid>

            <!-- Store Inventory, Item Palette, and Item Details -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <!-- Store Inventory -->
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="5"/>
                    <!-- Item Palette -->
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="5"/>
                    <!-- Item Details -->
                    <ColumnDefinition Width="250" MinWidth="180"/>
                </Grid.ColumnDefinitions>

                <!-- Store Inventory Panel -->
                <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4"
                        AutomationProperties.AutomationId="StoreInventoryPanel">
                    <DockPanel>
                        <!-- Header -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" Padding="8">
                            <TextBlock Text="Store Inventory" FontWeight="Bold"/>
                        </Border>

                        <!-- Search/Filter Bar -->
                        <Border DockPanel.Dock="Top" Padding="8" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="StoreSearchBox" Watermark="Search items..." TextChanged="OnStoreSearchTextChanged" AutomationProperties.AutomationId="StoreSearchBox"/>
                                <Button Grid.Column="1" Content="X" Width="28" Margin="4,0,0,0" Click="OnClearStoreSearch" AutomationProperties.AutomationId="ClearStoreSearchButton"/>
                            </Grid>
                        </Border>

                        <!-- Action Buttons (must dock before DataGrid fills remaining space) -->
                        <Border DockPanel.Dock="Bottom" Padding="8" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Select All" Click="OnSelectAllStoreItems" ToolTip.Tip="Select all items in the store" AutomationProperties.AutomationId="SelectAllStoreButton"/>
                                <Button Content="Remove" Click="OnRemoveFromStore" ToolTip.Tip="Remove selected items from store" AutomationProperties.AutomationId="RemoveFromStoreButton"/>
                                <Separator Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="4,2"/>
                                <Button Content="Make ∞" Click="OnSetInfinite" ToolTip.Tip="Set selected items to infinite stock" AutomationProperties.AutomationId="SetInfiniteButton"/>
                                <Button Content="∞ All" Click="OnSetAllInfinite" ToolTip.Tip="Set ALL items to infinite stock" AutomationProperties.AutomationId="SetAllInfiniteButton"/>
                                <Button Content="Clear ∞" Click="OnClearInfinite" ToolTip.Tip="Clear infinite flag on selected items" AutomationProperties.AutomationId="ClearInfiniteButton"/>
                            </StackPanel>
                        </Border>

                        <!-- Item List (fills remaining space - must be last in DockPanel) -->
                        <DataGrid x:Name="StoreInventoryGrid"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="False"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal"
                                  SelectionChanged="OnStoreInventorySelectionChanged"
                                  AutomationProperties.AutomationId="StoreInventoryGrid">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Toggle ∞" Click="OnContextToggleInfinite"/>
                                    <Separator/>
                                    <MenuItem Header="Copy ResRef" Click="OnContextCopyStoreResRef"/>
                                    <MenuItem Header="Copy Tag" Click="OnContextCopyStoreTag"/>
                                    <MenuItem Header="Copy Name" Click="OnContextCopyStoreName"/>
                                    <Separator/>
                                    <MenuItem Header="Remove from Store" Click="OnRemoveFromStore"/>
                                    <Separator/>
                                    <MenuItem Header="Select All" Click="OnSelectAllStoreItems"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="∞" Width="45" CanUserSort="True" SortMemberPath="Infinite">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="∞" ToolTip.Tip="Infinite stock - item never runs out" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" PointerPressed="OnInfiniteCellClicked">
                                                <TextBlock Text="{Binding Infinite, Converter={StaticResource InfiniteToSymbolConverter}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="Bold" FontSize="16"
                                                           Cursor="Hand"
                                                           ToolTip.Tip="Click to toggle infinite stock"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Name" Width="*" Binding="{Binding DisplayName}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Type" Width="100" Binding="{Binding BaseItemType}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Value" Width="60" Binding="{Binding BaseValue}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Sell" Width="60" Binding="{Binding SellPrice}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Buy" Width="60" Binding="{Binding BuyPrice}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="ResRef" Width="120" Binding="{Binding ResRef}"/>
                                <DataGridTextColumn Header="Tag" Width="120" Binding="{Binding Tag}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                              AutomationProperties.AutomationId="MainSplitter"/>

                <!-- Item Palette Panel -->
                <Border Grid.Column="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4"
                        AutomationProperties.AutomationId="ItemPalettePanel">
                    <DockPanel>
                        <!-- Header -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" Padding="8">
                            <TextBlock Text="Item Palette" FontWeight="Bold"/>
                        </Border>

                        <!-- Filter Bar -->
                        <Border DockPanel.Dock="Top" Padding="8" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Spacing="4">
                                <!-- Search -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="PaletteSearchBox" Watermark="Search items..." TextChanged="OnPaletteSearchTextChanged" AutomationProperties.AutomationId="PaletteSearchBox"/>
                                    <Button Grid.Column="1" Content="X" Width="28" Margin="4,0,0,0" Click="OnClearPaletteSearch" AutomationProperties.AutomationId="ClearPaletteSearchButton"/>
                                </Grid>

                                <!-- Source Filter -->
                                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <CheckBox x:Name="StandardItemsCheck" Content="Standard" IsChecked="True" Margin="0,0,12,0" IsCheckedChanged="OnSourceFilterChanged" AutomationProperties.AutomationId="StandardItemsCheck"/>
                                    <CheckBox x:Name="CustomItemsCheck" Content="Custom" IsChecked="False" IsCheckedChanged="OnSourceFilterChanged" AutomationProperties.AutomationId="CustomItemsCheck"/>
                                </WrapPanel>

                                <!-- Type Filter -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <TextBlock Text="Type:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ItemTypeFilter" MinWidth="200" SelectionChanged="OnTypeFilterChanged" AutomationProperties.AutomationId="ItemTypeFilter"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons (must dock before DataGrid fills remaining space) -->
                        <Border DockPanel.Dock="Bottom" Padding="8" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Add to Store" Click="OnAddToStore" AutomationProperties.AutomationId="AddToStoreButton"/>
                            </StackPanel>
                        </Border>

                        <!-- Item List (fills remaining space - must be last in DockPanel) -->
                        <DataGrid x:Name="ItemPaletteGrid"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal"
                                  SelectionChanged="OnPaletteSelectionChanged"
                                  AutomationProperties.AutomationId="ItemPaletteGrid">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Add to Store" Click="OnAddToStore"/>
                                    <Separator/>
                                    <MenuItem Header="Copy ResRef" Click="OnContextCopyPaletteResRef"/>
                                    <MenuItem Header="Copy Tag" Click="OnContextCopyPaletteTag"/>
                                    <MenuItem Header="Copy Name" Click="OnContextCopyPaletteName"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Width="*" Binding="{Binding DisplayName}"/>
                                <DataGridTextColumn Header="Type" Width="100" Binding="{Binding BaseItemType}"/>
                                <DataGridTextColumn Header="Value" Width="60" Binding="{Binding BaseValue}"/>
                                <DataGridTextColumn Header="ResRef" Width="120" Binding="{Binding ResRef}"/>
                                <DataGridTextColumn Header="Tag" Width="120" Binding="{Binding Tag}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Details Splitter -->
                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                              AutomationProperties.AutomationId="DetailsSplitter"/>

                <!-- Item Details Panel -->
                <Border Grid.Column="4" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4"
                        AutomationProperties.AutomationId="ItemDetailsPanel">
                    <DockPanel>
                        <!-- Header -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" Padding="8">
                            <TextBlock Text="Item Details" FontWeight="Bold"/>
                        </Border>

                        <!-- No Selection Message -->
                        <TextBlock x:Name="NoSelectionText"
                                   Text="Select an item to view details"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   AutomationProperties.AutomationId="NoSelectionText"/>

                        <!-- Item Details Content (overlays NoSelectionText when visible) -->
                        <ScrollViewer x:Name="ItemDetailsScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="False">
                            <StackPanel x:Name="ItemDetailsContent" Spacing="8" Margin="10">
                                <!-- Item Name -->
                                <TextBlock x:Name="DetailItemName"
                                           Text=""
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           AutomationProperties.AutomationId="DetailItemName"/>

                                <!-- Base Item Type -->
                                <TextBlock x:Name="DetailItemType"
                                           Text=""
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           HorizontalAlignment="Center"
                                           AutomationProperties.AutomationId="DetailItemType"/>

                                <!-- Separator -->
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,8,0,0"
                                        Margin="0,4,0,0">
                                    <StackPanel Spacing="6">
                                        <!-- ResRef -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="ResRef:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailResRef"
                                                       Text="" FontFamily="Consolas"
                                                       AutomationProperties.AutomationId="DetailResRef"/>
                                        </Grid>

                                        <!-- Tag -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Tag:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailTag"
                                                       Text="" FontFamily="Consolas"
                                                       AutomationProperties.AutomationId="DetailTag"/>
                                        </Grid>

                                        <!-- Value -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Value:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailValue"
                                                       Text=""
                                                       AutomationProperties.AutomationId="DetailValue"/>
                                        </Grid>

                                        <!-- Sell Price -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Sell:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailSellPrice"
                                                       Text=""
                                                       AutomationProperties.AutomationId="DetailSellPrice"/>
                                        </Grid>

                                        <!-- Buy Price -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Buy:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailBuyPrice"
                                                       Text=""
                                                       AutomationProperties.AutomationId="DetailBuyPrice"/>
                                        </Grid>

                                        <!-- Infinite -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Infinite:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailInfinite"
                                                       Text=""
                                                       AutomationProperties.AutomationId="DetailInfinite"/>
                                        </Grid>

                                        <!-- Store Panel -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0" Text="Panel:"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" x:Name="DetailStorePanel"
                                                       Text=""
                                                       AutomationProperties.AutomationId="DetailStorePanel"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
