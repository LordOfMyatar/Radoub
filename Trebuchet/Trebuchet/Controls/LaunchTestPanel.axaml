<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RadoubLauncher.ViewModels"
             x:Class="RadoubLauncher.Controls.LaunchTestPanel"
             x:DataType="vm:MainWindowViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="24">

            <!-- Launch Game Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="Launch Game"
                           FontSize="{DynamicResource FontSizeLarge}"
                           FontWeight="SemiBold"/>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Launch NWN:EE"
                            Command="{Binding LaunchGameCommand}"
                            IsEnabled="{Binding IsGameAvailable}"
                            Padding="16,8"
                            ToolTip.Tip="Launch Neverwinter Nights: Enhanced Edition"/>
                    <Button Content="Test Module"
                            Command="{Binding LaunchTestModuleCommand}"
                            IsEnabled="{Binding CanTestModule}"
                            Padding="16,8"
                            ToolTip.Tip="Launch with current module, auto-select first character"/>
                    <Button Content="Load Module"
                            Command="{Binding LaunchLoadModuleCommand}"
                            IsEnabled="{Binding CanLoadModule}"
                            Padding="16,8"
                            ToolTip.Tip="{Binding LoadModuleTooltip}"/>
                </StackPanel>

                <!-- DefaultBic Setting -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <CheckBox Content="Use Default Character"
                              IsChecked="{Binding UseDefaultBic}"
                              VerticalAlignment="Center"
                              ToolTip.Tip="When enabled, new players use the selected pre-generated character. Only Test Module works with DefaultBic."/>
                    <ComboBox ItemsSource="{Binding AvailableBicFiles}"
                              SelectedItem="{Binding SelectedDefaultBic}"
                              IsEnabled="{Binding IsDefaultBicDropdownEnabled}"
                              Width="180"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding NoBicFilesMessage}"
                               FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource ThemeWarning}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !HasBicFilesAvailable}"/>
                </StackPanel>

                <CheckBox Content="Always save before testing"
                          IsChecked="{Binding AlwaysSaveBeforeTesting}"
                          ToolTip.Tip="Automatically Build &amp; Save before launching Test Module"/>

                <TextBlock Text="Game not configured - set Base Game Path in Settings"
                           FontSize="{DynamicResource FontSizeSmall}"
                           Opacity="0.6"
                           IsVisible="{Binding !IsGameAvailable}"/>
            </StackPanel>

            <!-- Separator -->
            <Border Height="1"
                    Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

            <!-- Build Status Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="Build Status"
                           FontSize="{DynamicResource FontSizeLarge}"
                           FontWeight="SemiBold"/>

                <!-- Build warning indicator -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        IsVisible="{Binding NeedsBuildWarning}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚠"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       VerticalAlignment="Center"
                                       x:Name="BuildWarningIcon"/>
                            <TextBlock Text="{Binding BuildWarningText}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       x:Name="BuildWarningTextBlock"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Build &amp; Save"
                                    Command="{Binding BuildModuleCommand}"
                                    IsEnabled="{Binding CanBuildModule}"
                                    Padding="12,6"
                                    ToolTip.Tip="Save all changes and pack module to .mod file"/>
                            <Button Content="Test Anyway"
                                    Command="{Binding LaunchTestModuleCommand}"
                                    IsEnabled="{Binding CanTestModule}"
                                    Padding="12,6"
                                    ToolTip.Tip="Launch test without building — game uses the last built .mod"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Failed Scripts List -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        IsVisible="{Binding HasFailedScripts}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✕"
                                       FontSize="{DynamicResource FontSizeMedium}"
                                       VerticalAlignment="Center"
                                       x:Name="FailedScriptsIcon"/>
                            <TextBlock Text="Failed Scripts"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding FailedScriptItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FailedScriptItem">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ScriptName}"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ErrorSummary}"
                                                   Opacity="0.5"
                                                   FontSize="{DynamicResource FontSizeSmall}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="400"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Recompile Selected"
                                    Command="{Binding RecompileSelectedScriptsCommand}"
                                    Padding="12,6"
                                    ToolTip.Tip="Recompile only the checked scripts — successes are removed, failures updated"/>
                            <Button Content="Open in Editor"
                                    Command="{Binding OpenFailedScriptsInEditorCommand}"
                                    Padding="12,6"
                                    ToolTip.Tip="Open selected scripts in configured code editor"/>
                            <Button Content="Select All"
                                    Command="{Binding SelectAllFailedScriptsCommand}"
                                    Padding="8,4"
                                    FontSize="{DynamicResource FontSizeSmall}"/>
                            <Button Content="Select None"
                                    Command="{Binding SelectNoneFailedScriptsCommand}"
                                    Padding="8,4"
                                    FontSize="{DynamicResource FontSizeSmall}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- No warnings - all clear -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding !NeedsBuildWarning}">
                    <TextBlock Text="✓"
                               FontSize="{DynamicResource FontSizeMedium}"
                               VerticalAlignment="Center"
                               x:Name="BuildOkIcon"/>
                    <TextBlock Text="Module is up to date"
                               Opacity="0.7"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Compiler Log Folder button - visible when a log exists from last build -->
                <Button Content="Open Compiler Log Folder"
                        Command="{Binding OpenBuildLogFolderCommand}"
                        IsVisible="{Binding HasBuildLog}"
                        Padding="12,6"
                        ToolTip.Tip="Open the folder containing compiler build logs"/>

                <!-- Build progress -->
                <StackPanel IsVisible="{Binding IsBuilding}" Spacing="8">
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"/>
                    <TextBlock Text="{Binding BuildStatusText}"
                               Opacity="0.7"/>
                </StackPanel>

                <!-- Build Options -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox Content="Compile scripts before building"
                                  IsChecked="{Binding CompileScriptsEnabled}"
                                  IsEnabled="{Binding IsCompilerAvailable}"
                                  ToolTip.Tip="Run the NWScript compiler before packing the module"/>
                        <TextBlock Text="(compiler not found)"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Opacity="0.4"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !IsCompilerAvailable}"/>
                    </StackPanel>

                    <StackPanel Margin="24,0,0,0" Spacing="2"
                                IsEnabled="{Binding CompileScriptsEnabled}">
                        <RadioButton Content="Compile all scripts"
                                     IsChecked="{Binding BuildUncompiledScriptsEnabled}"
                                     GroupName="CompileMode"
                                     ToolTip.Tip="Compile changed scripts and scripts with no .ncs (skips include/library files)"/>
                        <RadioButton Content="Only compile changed scripts"
                                     IsChecked="{Binding OnlyCompileChangedScripts}"
                                     GroupName="CompileMode"
                                     ToolTip.Tip="Only recompile .nss files that are newer than their .ncs"/>
                    </StackPanel>

                    <!-- Script Compiler Path -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Script Compiler:"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ScriptCompilerPath}"
                                     Watermark="Path to nwn_script_comp — leave blank for bundled"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseScriptCompilerPathCommand}"
                                    Padding="8,4"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="2"
                                    Content="Clear"
                                    Command="{Binding ClearScriptCompilerPathCommand}"
                                    Padding="8,4"/>
                        </Grid>
                        <TextBlock Text="{Binding CompilerSourceDescription}"
                                   Opacity="0.5"
                                   FontSize="{DynamicResource FontSizeSmall}"/>
                    </StackPanel>

                    <!-- Code Editor Path -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Code Editor:"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding CodeEditorPath}"
                                     Watermark="Path to code editor — leave blank for system default"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseCodeEditorPathCommand}"
                                    Padding="8,4"/>
                        </Grid>
                        <TextBlock Text="Used to open failed scripts. Leave blank to use system default."
                                   Opacity="0.5"
                                   FontSize="{DynamicResource FontSizeSmall}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stale script details -->
                <TextBlock FontSize="{DynamicResource FontSizeSmall}"
                           Opacity="0.6"
                           x:Name="StaleScriptText"
                           IsVisible="False"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
