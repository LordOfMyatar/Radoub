<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RadoubLauncher.Views.ReplacePreviewWindow"
        Title="Replace Preview"
        Width="650" Height="500"
        MinWidth="450" MinHeight="350"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock x:Name="HeaderText" FontWeight="SemiBold"/>
                <DockPanel>
                    <TextBlock x:Name="SelectionCount" DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Select All" Click="OnSelectAllClick"
                                Padding="8,2" FontSize="{DynamicResource FontSizeSmall}"/>
                        <Button Content="Deselect All" Click="OnDeselectAllClick"
                                Padding="8,2" FontSize="{DynamicResource FontSizeSmall}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Change list -->
        <TreeView x:Name="ChangeTree" Grid.Row="1" Margin="4">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
            </TreeView.Styles>
        </TreeView>

        <!-- Backup notice -->
        <Border Grid.Row="2" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="⚠ Backup will be created in ~/Radoub/Backups/ before replacing."
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="3" Padding="12,8"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="ExecuteButton" Content="Execute Replace"
                        Click="OnExecuteClick" Padding="16,6"/>
                <Button Content="Cancel" Click="OnCancelClick" Padding="16,6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
