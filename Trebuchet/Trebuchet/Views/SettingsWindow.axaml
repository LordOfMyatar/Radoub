<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RadoubLauncher.ViewModels"
        x:Class="RadoubLauncher.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings - Trebuchet"
        Width="620" Height="560"
        MinWidth="520" MinHeight="460"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:SettingsWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">
        <!-- Setup-mode welcome / review banner (#2419) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding IsSetupMode}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding BannerText}"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Bottom Buttons: Next (setup convenience) / Save / Cancel -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="Next ▶"
                    Command="{Binding NextCommand}"
                    IsVisible="{Binding IsSetupMode}"
                    Padding="16,8"/>
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Padding="16,8"/>
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Padding="16,8"/>
        </StackPanel>

        <!-- Settings Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Tab 0: Game / Home Locations -->
            <TabItem Header="Game / Home">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible"
                              Padding="0,8,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Game Paths"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"/>

                        <!-- Base Game Installation (Steam/GOG) -->
                        <StackPanel Margin="0,8,0,0" Spacing="4">
                            <TextBlock Text="Base Game Installation (Steam/GOG):"
                                       FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding GameInstallPath}"
                                         Watermark="Path to NWN installation (contains data\ folder)"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Command="{Binding BrowseGamePathCommand}"
                                        Margin="0,0,4,0"
                                        Padding="8,4"/>
                                <Button Grid.Column="2"
                                        Content="Auto-Detect"
                                        Command="{Binding AutoDetectGamePathCommand}"
                                        Padding="8,4"/>
                            </Grid>
                            <TextBlock Text="{Binding GameInstallValidation}"
                                       Foreground="{Binding GameInstallValidationColor}"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       IsVisible="{Binding HasGameInstallValidation}"/>
                        </StackPanel>

                        <!-- NWN Documents (User Data) -->
                        <StackPanel Margin="0,8,0,0" Spacing="4">
                            <TextBlock Text="NWN Documents (User Data):"
                                       FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding NwnDocumentsPath}"
                                         Watermark="Path to Documents\Neverwinter Nights"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Command="{Binding BrowseDocumentsPathCommand}"
                                        Margin="0,0,4,0"
                                        Padding="8,4"/>
                                <Button Grid.Column="2"
                                        Content="Auto-Detect"
                                        Command="{Binding AutoDetectDocumentsPathCommand}"
                                        Padding="8,4"/>
                            </Grid>
                            <TextBlock Text="{Binding NwnDocumentsValidation}"
                                       Foreground="{Binding NwnDocumentsValidationColor}"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       IsVisible="{Binding HasNwnDocumentsValidation}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 1: Logging -->
            <TabItem Header="Logging">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible"
                              Padding="0,8,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Logging"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Manage logs for all Radoub tools"
                                   Opacity="0.7"
                                   FontSize="{DynamicResource FontSizeSmall}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Log Level:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <StackPanel Grid.Row="0" Grid.Column="1"
                                        Orientation="Horizontal" Spacing="8">
                                <ComboBox ItemsSource="{Binding AvailableLogLevels}"
                                          SelectedItem="{Binding SelectedLogLevel}"
                                          MinWidth="200"/>
                                <TextBlock Text="(Shared)"
                                           VerticalAlignment="Center"
                                           Opacity="0.6"
                                           IsVisible="{Binding IsSharedLogging}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Session Retention:"
                                       VerticalAlignment="Center"
                                       Margin="0,8,12,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <Slider Value="{Binding LogRetentionSessions}"
                                        Minimum="1"
                                        Maximum="10"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Width="200"/>
                                <TextBlock Text="{Binding LogRetentionText}"
                                           VerticalAlignment="Center"
                                           Width="80"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <Button Content="Open Radoub Folder"
                                        Command="{Binding OpenLogFolderCommand}"
                                        Padding="8,4"/>
                                <Button Content="Cleanup Logs"
                                        Command="{Binding CleanupLogsCommand}"
                                        Padding="8,4"/>
                                <Button Content="Export Logs for Support..."
                                        Command="{Binding ExportLogsCommand}"
                                        Padding="8,4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Backups -->
            <TabItem Header="Backups">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible"
                              Padding="0,8,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Backups"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Manage backup files created by search and replace operations"
                                   Opacity="0.7"
                                   FontSize="{DynamicResource FontSizeSmall}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Retention (Days):"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <StackPanel Grid.Row="0" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Slider Value="{Binding BackupRetentionDays}"
                                        Minimum="1"
                                        Maximum="90"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Width="200"/>
                                <TextBlock Text="{Binding BackupRetentionText}"
                                           VerticalAlignment="Center"
                                           Width="80"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <Button Content="Delete All Backups"
                                        Command="{Binding DeleteAllBackupsCommand}"
                                        Padding="8,4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Appearance -->
            <TabItem Header="Appearance">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible"
                              Padding="0,8,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Appearance"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Theme:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      MinWidth="200"/>
                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="Create Theme..."
                                    Command="{Binding OpenThemeEditorCommand}"
                                    Margin="8,0,0,0"
                                    Padding="8,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Font Size:"
                                       VerticalAlignment="Center"
                                       Margin="0,8,12,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <Slider Value="{Binding FontSizePoints}"
                                        Minimum="8"
                                        Maximum="32"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Width="200"/>
                                <TextBlock Text="{Binding FontSizePointsText}"
                                           VerticalAlignment="Center"
                                           Width="50"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: Review -->
            <TabItem Header="Review">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Visible"
                              Padding="0,8,12,0">
                    <StackPanel Spacing="16">

                        <!-- First-run only: choose a module to open -->
                        <StackPanel Spacing="8" IsVisible="{Binding ShowModulePicker}">
                            <TextBlock Text="Open a Module"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Pick a module to start working with now, or skip and open one later."
                                       Opacity="0.7"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Choose a module..."
                                        Command="{Binding ChooseModuleCommand}"
                                        Padding="8,4"/>
                                <TextBlock Text="{Binding ChosenModuleDisplay}"
                                           VerticalAlignment="Center"
                                           Opacity="0.85"/>
                            </StackPanel>
                            <CheckBox Content="Create a desktop shortcut for Trebuchet"
                                      IsChecked="{Binding CreateDesktopShortcut}"/>
                            <TextBlock Text="{Binding ShortcutResultMessage}"
                                       IsVisible="{Binding HasShortcutResult}"
                                       TextWrapping="Wrap"
                                       Opacity="0.85"/>
                        </StackPanel>

                        <!-- Detected Tools (Read-Only Info) -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Detected Tools"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Tools are automatically detected. Run each tool once to register its location."
                                       Opacity="0.7"
                                       FontSize="{DynamicResource FontSizeSmall}"/>

                            <ItemsControl ItemsSource="{Binding DetectedTools}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="120,*" Margin="0,2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StatusText}"
                                                       Opacity="0.7"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
