<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RadoubLauncher.ViewModels"
        xmlns:svc="using:RadoubLauncher.Services"
        xmlns:ctrl="using:RadoubLauncher.Controls"
        xmlns:sys="using:System"
        xmlns:conv="using:RadoubLauncher.ViewModels"
        xmlns:radoubControls="using:Radoub.UI.Controls"
        x:Class="RadoubLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWindowRoot"
        Title="Trebuchet - Radoub Toolset (Alpha)"
        Icon="avares://Trebuchet/Assets/Trebuchet.ico"
        Width="900" Height="600"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="30">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Buttons on accent header bar: semi-transparent white background -->
        <Style Selector="Border.AccentBar Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Border.AccentBar Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#55FFFFFF"/>
        </Style>
        <Style Selector="Border.AccentBar Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
        </Style>

        <!-- Sidebar recent module item hover -->
        <Style Selector="Button.SidebarRecentItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.SidebarRecentItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ThemeTitleBar}"
                Height="30"
                x:Name="TitleBar"
                PointerPressed="OnTitleBarPointerPressed"
                DoubleTapped="OnTitleBarDoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        IsHitTestVisible="False">
                <Image Source="avares://Trebuchet/Assets/Trebuchet.ico"
                       Width="{DynamicResource GlobalFontSize}"
                       Height="{DynamicResource GlobalFontSize}"
                       Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeTitleBarForeground}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Module Info -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Module:"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ModuleNameText"
                               Text="{Binding CurrentModuleName, FallbackValue='(No module)'}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="250"/>
                    <Separator Width="1" Margin="4,0" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                    <Button Content="Open..."
                            Command="{Binding OpenModuleCommand}"
                            Padding="8,4"/>
                    <Button Content="Save Module"
                            Command="{Binding BuildModuleCommand}"
                            IsEnabled="{Binding CanBuildModule}"
                            Padding="8,4"
                            ToolTip.Tip="Save IFO changes and pack working directory into .mod file"/>
                    <Button Content="Import ERF..."
                            Click="OnImportErfClick"
                            IsVisible="{Binding IsModuleUnpacked}"
                            Padding="8,4"
                            ToolTip.Tip="Import resources from an ERF, HAK, or MOD archive"/>
                    <!-- Build warning indicator -->
                    <TextBlock Text="⚠"
                               Foreground="{DynamicResource ThemeWarning}"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeMedium}"
                               Margin="-4,0,0,0"
                               IsVisible="{Binding NeedsBuildWarning}"
                               ToolTip.Tip="{Binding BuildWarningText}"/>
                    <Separator Width="1" Margin="4,0" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                    <Button Content="Test Module"
                            Command="{Binding LaunchTestModuleCommand}"
                            IsEnabled="{Binding CanTestModule}"
                            Padding="8,4"
                            ToolTip.Tip="Launch with current module, auto-select first character"/>
                </StackPanel>

                <!-- Settings and Help Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="About"
                            Command="{Binding OpenAboutCommand}"
                            Padding="8,4"/>
                    <Button Content="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Padding="8,4"/>
                    <Button Content="Edit Settings File"
                            Command="{Binding EditSettingsFileCommand}"
                            Padding="8,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar (bottom position) -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto">
            <radoubControls:StatusBarControl x:Name="StatusBar"
                                             PrimaryText="{Binding GameStatusText}"
                                             SecondaryText="{Binding BuildStatusText}"
                                             TertiaryText="{Binding TlkStatusText}"
                                             ShowProgress="{Binding IsBuilding}"/>

            <!-- Update Status -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="16,0"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding UpdateStatusText}"
                           Opacity="0.7"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !UpdateAvailable}"/>
                <Border Background="{DynamicResource ThemeInfoBrush}"
                        CornerRadius="4"
                        Padding="8,4"
                        IsVisible="{Binding UpdateAvailable}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   Foreground="{DynamicResource ThemeAccentForeground}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Content="Download"
                                Command="{Binding OpenReleasePageCommand}"
                                Padding="8,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Version -->
            <TextBlock Grid.Column="2"
                       Text="{Binding VersionText}"
                       Opacity="0.5"
                       Margin="8,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Content: Sidebar + Workspace -->
        <Grid ColumnDefinitions="200,Auto,*">

            <!-- Left Sidebar -->
            <Border Background="{DynamicResource ThemeBackgroundAlt}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8">
                        <!-- Tools Section -->
                        <TextBlock Text="TOOLS"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   FontWeight="SemiBold"
                                   Opacity="0.6"
                                   Margin="12,0,12,4"/>

                        <ItemsControl ItemsSource="{Binding Tools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="svc:ToolInfo">
                                    <ctrl:SidebarToolItemControl DataContext="{Binding}"
                                                                  LaunchToolCommand="{Binding #MainWindowRoot.DataContext.LaunchToolCommand}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Separator -->
                        <Border Height="1"
                                Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                Margin="12,8"/>

                        <!-- Recent Modules Section -->
                        <Grid Margin="12,0,12,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="RECENT MODULES"
                                       FontSize="{DynamicResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Opacity="0.6"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Clear"
                                    Command="{Binding ClearRecentModulesCommand}"
                                    Padding="4,1"
                                    FontSize="{DynamicResource FontSizeXSmall}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    IsVisible="{Binding HasRecentModules}"
                                    ToolTip.Tip="Clear recent modules list"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding RecentModules}"
                                      IsVisible="{Binding HasRecentModules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="sys:String">
                                    <Button Classes="SidebarRecentItem"
                                            Command="{Binding #MainWindowRoot.DataContext.OpenRecentModuleCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding}">
                                        <TextBlock Text="{Binding Converter={x:Static conv:PathToFilenameConverter.Instance}}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="{DynamicResource FontSizeSmall}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="No recent modules"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Opacity="0.4"
                                   Margin="12,4"
                                   IsVisible="{Binding !HasRecentModules}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns"/>

            <!-- Workspace -->
            <Grid Grid.Column="2">
                <!-- Empty state: no module loaded -->
                <Border x:Name="EmptyStatePanel"
                        IsVisible="{Binding !HasModule}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <TextBlock Text="Welcome to Trebuchet"
                                   FontSize="{DynamicResource FontSizeTitle}"
                                   FontWeight="Light"
                                   HorizontalAlignment="Center"
                                   Opacity="0.6"/>
                        <TextBlock Text="Select a module to get started"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   HorizontalAlignment="Center"
                                   Opacity="0.4"/>
                        <Button Content="Open Module..."
                                Command="{Binding OpenModuleCommand}"
                                Padding="20,10"
                                HorizontalAlignment="Center"
                                FontSize="{DynamicResource FontSizeLarge}"/>
                        <TextBlock Text="Game not configured - set Base Game Path in Settings"
                                   FontSize="{DynamicResource FontSizeSmall}"
                                   Opacity="0.4"
                                   HorizontalAlignment="Center"
                                   IsVisible="{Binding !IsGameAvailable}"/>
                    </StackPanel>
                </Border>

                <!-- Workspace TabControl: visible when module loaded -->
                <TabControl x:Name="WorkspaceTabs"
                            Classes="WorkspaceTabs"
                            IsVisible="{Binding HasModule}">

                    <!-- Module Tab -->
                    <TabItem Header="Module">
                        <ctrl:ModuleEditorPanel x:Name="ModuleEditorPanel"/>
                    </TabItem>

                    <!-- Factions Tab -->
                    <TabItem Header="Factions">
                        <ctrl:FactionEditorPanel x:Name="FactionEditorPanel"/>
                    </TabItem>

                    <!-- Build & Test Tab -->
                    <TabItem Header="Build &amp; Test">
                        <ctrl:LaunchTestPanel x:Name="LaunchTestPanel"/>
                    </TabItem>

                    <!-- Marlinspike Tab -->
                    <TabItem Header="Marlinspike">
                        <ctrl:MarlinspikePanel x:Name="MarlinspikePanel"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
