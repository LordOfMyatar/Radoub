<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Views.ModuleSearchWindow"
        Title="Search Module"
        Width="750" Height="550"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Search Criteria -->
        <Border Grid.Row="0" Padding="10,8"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <!-- Search pattern -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" x:Name="SearchButton" Content="Search"
                            Click="OnSearchClick" Margin="8,0,0,0" Padding="16,4"
                            IsDefault="True"/>
                    <Button DockPanel.Dock="Right" x:Name="CancelButton" Content="Cancel"
                            Click="OnCancelClick" Margin="4,0,0,0" Padding="12,4"
                            IsVisible="False"/>
                    <TextBox x:Name="SearchPatternBox" Watermark="Search pattern..."
                             KeyDown="OnSearchPatternKeyDown"/>
                </DockPanel>

                <!-- Replace pattern -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" x:Name="ReplaceAllButton" Content="Replace All"
                            Click="OnReplaceAllClick" Margin="4,0,0,0" Padding="12,4"
                            IsEnabled="False"
                            ToolTip.Tip="Replace all matches in all files"/>
                    <Button DockPanel.Dock="Right" x:Name="ReplaceSelectedButton" Content="Replace Selected"
                            Click="OnReplaceSelectedClick" Margin="4,0,0,0" Padding="12,4"
                            IsEnabled="False"
                            ToolTip.Tip="Replace only checked matches"/>
                    <TextBox x:Name="ReplacePatternBox" Watermark="Replace with..."/>
                </DockPanel>

                <!-- Options row -->
                <WrapPanel>
                    <CheckBox x:Name="CaseSensitiveCheck" Content="Case sensitive" Margin="0,0,12,0"/>
                    <CheckBox x:Name="RegexCheck" Content="Regex" Margin="0,0,12,0"/>
                    <TextBlock Text="Fields:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox x:Name="FieldFilterCombo" SelectedIndex="0" MinWidth="120">
                        <ComboBoxItem Content="All Fields"/>
                        <ComboBoxItem Content="Text" Tag="Content"/>
                        <ComboBoxItem Content="Tags/Identity" Tag="Identity"/>
                        <ComboBoxItem Content="Scripts" Tag="Script"/>
                        <ComboBoxItem Content="Metadata" Tag="Metadata"/>
                    </ComboBox>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Status / Progress -->
        <Border Grid.Row="1" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <ProgressBar x:Name="SearchProgress" DockPanel.Dock="Right"
                             Width="120" Height="12" Margin="8,0,0,0"
                             IsIndeterminate="True" IsVisible="False"/>
                <TextBlock x:Name="StatusText" Text="Enter a search pattern and click Search."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </DockPanel>
        </Border>

        <!-- Results Tree -->
        <TreeView x:Name="ResultsTree" Grid.Row="2" Margin="4"
                  DoubleTapped="OnResultDoubleTapped">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
            </TreeView.Styles>
        </TreeView>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="ModulePathText" DockPanel.Dock="Left"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="DurationText" DockPanel.Dock="Right"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" FontSize="11"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
