<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Radoub.UI.Controls.SearchBar"
             IsVisible="False">
    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            Padding="5,3">
        <StackPanel Spacing="3">
            <!-- Search row -->
            <DockPanel>
                <!-- Close button -->
                <Button DockPanel.Dock="Right" Content="✕" Click="OnCloseClick"
                        Padding="6,2" Margin="3,0,0,0"
                        ToolTip.Tip="Close (Escape)"
                        Background="Transparent" BorderThickness="0"
                        IsTabStop="False"/>

                <!-- Match count -->
                <TextBlock x:Name="MatchCountText" DockPanel.Dock="Right"
                           VerticalAlignment="Center" Margin="8,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Text=""/>

                <!-- Navigation buttons -->
                <Button DockPanel.Dock="Right" Content="▼" Click="OnNextClick"
                        Padding="6,2" Margin="2,0"
                        ToolTip.Tip="Next match (F3)"
                        Background="Transparent" BorderThickness="0"
                        IsTabStop="False"/>
                <Button DockPanel.Dock="Right" Content="▲" Click="OnPreviousClick"
                        Padding="6,2" Margin="2,0"
                        ToolTip.Tip="Previous match (Shift+F3)"
                        Background="Transparent" BorderThickness="0"
                        IsTabStop="False"/>

                <!-- Field filter -->
                <ComboBox x:Name="FieldFilterCombo" DockPanel.Dock="Right"
                          SelectedIndex="0" Margin="5,0" MinWidth="100"
                          SelectionChanged="OnFieldFilterChanged"
                          ToolTip.Tip="Filter by field type"
                          IsTabStop="False"/>

                <!-- Options -->
                <CheckBox x:Name="CaseSensitiveCheck" DockPanel.Dock="Right"
                          Content="Aa" Margin="5,0" VerticalAlignment="Center"
                          ToolTip.Tip="Case sensitive"
                          IsCheckedChanged="OnOptionsChanged"
                          IsTabStop="False"/>

                <CheckBox x:Name="RegexCheck" DockPanel.Dock="Right"
                          Content=".*" Margin="5,0" VerticalAlignment="Center"
                          ToolTip.Tip="Regular expression"
                          IsCheckedChanged="OnOptionsChanged"
                          IsTabStop="False"/>

                <!-- Search text box -->
                <TextBox x:Name="SearchTextBox"
                         Watermark="Find... (Ctrl+F)"
                         Margin="0,0,5,0"
                         TabIndex="0"/>
            </DockPanel>

            <!-- Replace row (hidden by default, toggled with Ctrl+H) -->
            <DockPanel x:Name="ReplaceRow" IsVisible="False">
                <Button DockPanel.Dock="Right" Content="Replace All" Click="OnReplaceAllClick"
                        Padding="8,2" Margin="3,0,0,0"
                        ToolTip.Tip="Replace all matches"
                        TabIndex="3"/>
                <Button DockPanel.Dock="Right" Content="Replace" Click="OnReplaceClick"
                        Padding="8,2" Margin="3,0,0,0"
                        ToolTip.Tip="Replace current match"
                        TabIndex="2"/>
                <TextBox x:Name="ReplaceTextBox"
                         Watermark="Replace with..."
                         Margin="0,0,5,0"
                         TabIndex="1"/>
            </DockPanel>
        </StackPanel>
    </Border>
</UserControl>
