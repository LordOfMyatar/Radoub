<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ItemEditor.Views.NewItemWizardWindow"
        Title="New Item — Step 1 of 3: Item Type"
        Width="520" Height="580"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="NewItemWizardWindow">

    <DockPanel>
        <!-- Bottom navigation bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <!-- Validation message -->
                <TextBlock Grid.Column="0" x:Name="ValidationText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeError}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="1" x:Name="BackButton"
                        Content="← Back" Click="OnBackClick"
                        Width="80" Margin="0,0,8,0"
                        IsEnabled="False"/>
                <Button Grid.Column="2" x:Name="NextButton"
                        Content="Next →" Click="OnNextClick"
                        Width="100" Margin="0,0,8,0"
                        IsEnabled="False"/>
                <Button Grid.Column="3" Content="Cancel" Click="OnCancelClick"
                        Width="80"/>
            </Grid>
        </Border>

        <!-- Step panels container -->
        <Panel Margin="16">

            <!-- Step 1: Item Type Selection -->
            <DockPanel x:Name="Step1Panel" IsVisible="True">
                <TextBlock DockPanel.Dock="Top" Text="Select Base Item Type"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Category filter -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="Categories:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DropDownButton Grid.Column="1" x:Name="CategoryDropDown" Content="All Categories"
                                    HorizontalAlignment="Stretch">
                        <DropDownButton.Flyout>
                            <Flyout Placement="Bottom">
                                <StackPanel x:Name="CategoryCheckboxPanel" Width="200" Spacing="2">
                                    <CheckBox x:Name="SelectAllCheckBox" Content="Select All"
                                              IsChecked="True" Click="OnSelectAllCategoriesClick"/>
                                    <Separator Margin="0,2"/>
                                    <!-- Category checkboxes populated in code-behind -->
                                </StackPanel>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </Grid>

                <!-- Search box -->
                <TextBox DockPanel.Dock="Top" x:Name="TypeSearchBox"
                         Watermark="Search item types..."
                         Margin="0,4,0,4"
                         AutomationProperties.AutomationId="TypeSearchBox"/>

                <!-- Counter -->
                <TextBlock DockPanel.Dock="Top" x:Name="TypeCountText"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,0,0,4"/>

                <!-- Item type list -->
                <ListBox x:Name="TypeListBox"
                         SelectionChanged="OnTypeSelectionChanged"
                         AutomationProperties.AutomationId="TypeListBox"/>
            </DockPanel>

            <!-- Step 2: Name & Identity -->
            <StackPanel x:Name="Step2Panel" IsVisible="False" Spacing="8">
                <TextBlock Text="Name and Identity"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <!-- Selected type (read-only) -->
                <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Item Type" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="SelectedTypeLabel"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Grid>

                <!-- Name -->
                <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="NameTextBox"
                             Watermark="Enter item name"
                             AutomationProperties.AutomationId="WizardNameTextBox"/>
                </Grid>

                <!-- Tag -->
                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0" Text="Tag" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TagTextBox"
                             MaxLength="32"
                             Watermark="Item tag (max 32 chars)"
                             AutomationProperties.AutomationId="WizardTagTextBox"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="AutoTagCheckBox" Content="Auto-generate from name"
                                  IsChecked="True" Click="OnAutoTagCheckChanged"/>
                        <TextBlock x:Name="TagCharCount" FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ResRef -->
                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0" Text="ResRef" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ResRefTextBox"
                             MaxLength="16"
                             Watermark="Resource reference (max 16 chars)"
                             AutomationProperties.AutomationId="WizardResRefTextBox"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <CheckBox x:Name="AutoResRefCheckBox" Content="Auto-generate from name"
                                  IsChecked="True" Click="OnAutoResRefCheckChanged"/>
                        <TextBlock x:Name="ResRefCharCount" FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Step 3: Save & Finish -->
            <StackPanel x:Name="Step3Panel" IsVisible="False" Spacing="8">
                <TextBlock Text="Save and Finish"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <!-- Summary -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,0">
                        <Grid.Styles>
                            <Style Selector="TextBlock.sum-label">
                                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <Setter Property="Margin" Value="0,0,8,4"/>
                            </Style>
                            <Style Selector="TextBlock.sum-value">
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" Classes="sum-label"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SummaryType" Classes="sum-value"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Classes="sum-label"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SummaryName" Classes="sum-value"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tag" Classes="sum-label"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SummaryTag" Classes="sum-value"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="ResRef" Classes="sum-label"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SummaryResRef" Classes="sum-value"/>
                    </Grid>
                </Border>

                <!-- Palette category -->
                <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Category" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="PaletteCategoryComboBox"
                              HorizontalAlignment="Stretch"
                              AutomationProperties.AutomationId="WizardPaletteCategory"/>
                </Grid>

                <!-- Save location -->
                <Grid ColumnDefinitions="100,*,Auto">
                    <TextBlock Grid.Column="0" Text="Save to" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="SaveLocationTextBox"
                             IsReadOnly="True"
                             AutomationProperties.AutomationId="WizardSaveLocation"/>
                    <Button Grid.Column="2" Content="Browse..."
                            Click="OnBrowseSaveLocationClick"
                            Margin="8,0,0,0"/>
                </Grid>

                <!-- Filename -->
                <Grid ColumnDefinitions="100,*">
                    <TextBlock Grid.Column="0" Text="Filename" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="FilenameLabel"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Open after creation -->
                <CheckBox x:Name="OpenAfterCreateCheckBox"
                          Content="Open in Item Editor after creation"
                          IsChecked="True"
                          Margin="0,8,0,0"
                          AutomationProperties.AutomationId="WizardOpenAfterCreate"/>
            </StackPanel>
        </Panel>
    </DockPanel>
</Window>
