<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Radoub.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="420"
             x:Class="PlaceableEditor.Views.Panels.InventoryPanel"
             x:Name="InventoryPanelInstance"
             IsVisible="False">
    <Border Padding="16" Background="{DynamicResource ThemeBackground}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Inventory"
                       FontWeight="Bold"
                       FontSize="{DynamicResource FontSizeMedium}"
                       Margin="0,0,0,10"/>

            <!-- Backpack LEFT | UTI palette MIDDLE | details RIGHT (design §5.4, 3 splitters).
                 Adventurer-backpack model: flat list, no body slots. -->
            <!-- MaxHeight caps the inventory area inside the host ScrollViewer so each pane's
                 ItemListView (DataGrid) scrolls internally instead of growing the whole column and
                 pushing the docked Add/Remove buttons off-screen with long CEP lists (#2414). The
                 cap is generous and the lists scroll within it, so large-font layouts still work. -->
            <Grid x:Name="InventoryGrid" MinHeight="320" MaxHeight="520">
                <!-- All three content columns are proportional (star) so the two GridSplitters
                     redistribute space cleanly without leaving empty gaps; MinWidth floors keep
                     each pane usable at large fonts (#2363). -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" MinWidth="200"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="4*" MinWidth="240"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="3*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- Placeable Contents (backpack) -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="5">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Placeable Contents"
                                   FontWeight="Bold" Margin="0,0,0,5"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                    Spacing="5" Margin="0,5,0,0">
                            <Button Content="Remove" Click="OnRemoveClick"
                                    IsEnabled="{Binding HasBackpackSelection, ElementName=InventoryPanelInstance}"
                                    Padding="8,4"
                                    AutomationProperties.AutomationId="Reliquary_Button_RemoveItem"/>
                            <TextBlock x:Name="ContentsCount" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                        <controls:ItemListView x:Name="BackpackList"
                                               ContextKey="Backpack"
                                               ShowEquipMenuItem="False"
                                               AutomationProperties.AutomationId="Reliquary_BackpackList"/>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                <!-- UTI Palette -->
                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1" Padding="5">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="UTI Palette"
                                   FontWeight="Bold" Margin="0,0,0,5"/>
                        <controls:ItemFilterPanel x:Name="PaletteFilter"
                                                  DockPanel.Dock="Top"
                                                  ContextKey="ReliquaryPalette"
                                                  Margin="0,0,0,5"
                                                  AutomationProperties.AutomationId="Reliquary_PaletteFilter"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                    Spacing="5" Margin="0,5,0,0">
                            <Button Content="Add Selected" Click="OnAddSelectedClick"
                                    IsEnabled="{Binding HasPaletteSelection, ElementName=InventoryPanelInstance}"
                                    Padding="8,4"
                                    AutomationProperties.AutomationId="Reliquary_Button_AddItem"/>
                        </StackPanel>
                        <controls:ItemListView x:Name="PaletteList"
                                               ContextKey="Palette"
                                               ShowEquipMenuItem="False"
                                               AddToBackpackHeader="Add to Inventory"
                                               AutomationProperties.AutomationId="Reliquary_PaletteList"/>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>

                <!-- Item Details (read-only resolved UTI values; UTP stores no per-instance fields) -->
                <controls:ItemDetailsPanel Grid.Column="4"
                                           x:Name="ItemDetailsView"
                                           AutomationProperties.AutomationId="Reliquary_ItemDetails"/>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
