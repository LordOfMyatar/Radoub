<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Radoub.UI.Controls"
        xmlns:vm="using:ItemEditor.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="ItemEditor.Views.MainWindow"
        x:Name="MainWindowInstance"
        Title="ItemEditor"
        Width="1000" Height="700"
        MinWidth="700" MinHeight="500"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="30"
        KeyDown="OnWindowKeyDown">

    <DockPanel>
        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ThemeTitleBar}"
                Height="30"
                x:Name="TitleBar"
                PointerPressed="OnTitleBarPointerPressed"
                DoubleTapped="OnTitleBarDoubleTapped">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        IsHitTestVisible="False">
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeTitleBarForeground}"/>
            </StackPanel>
        </Border>

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" AutomationProperties.AutomationId="MainMenu">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Click="OnOpenClick" InputGesture="Ctrl+O"/>
                <MenuItem Header="Open _Recent" x:Name="RecentFilesMenu"/>
                <Separator/>
                <MenuItem Header="_Save" Click="OnSaveClick" InputGesture="Ctrl+S"
                          IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <MenuItem Header="Save _As..." Click="OnSaveAsClick" InputGesture="Ctrl+Shift+S"
                          IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <Separator/>
                <MenuItem Header="_Close" Click="OnCloseFileClick"
                          IsEnabled="{Binding HasFile, ElementName=MainWindowInstance}"/>
                <MenuItem Header="E_xit" Click="OnExitClick" InputGesture="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGesture="Ctrl+Z" IsEnabled="False" ToolTip.Tip="Not yet implemented"/>
                <MenuItem Header="_Redo" InputGesture="Ctrl+Y" IsEnabled="False" ToolTip.Tip="Not yet implemented"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="ItemBrowserMenuItem" Header="_Item Browser" Click="OnToggleItemBrowserClick" InputGesture="F4"/>
                <Separator/>
                <MenuItem x:Name="LanguageMenu" Header="_Language" AutomationProperties.AutomationId="LanguageMenu"/>
                <Separator/>
                <MenuItem Header="_Settings..." Click="OnSettingsClick"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About ItemEditor" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,8,*,8,Auto">
                <!-- Module indicator -->
                <TextBlock Grid.Column="0" x:Name="ModuleIndicator"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                <!-- Status text -->
                <TextBlock Grid.Column="2" x:Name="StatusText"
                           Text="Ready"
                           VerticalAlignment="Center"/>

                <!-- File path -->
                <TextBlock Grid.Column="4" x:Name="FilePathText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid ColumnDefinitions="Auto,4,*">
            <!-- Item Browser Panel (left sidebar) -->
            <Border Grid.Column="0" x:Name="ItemBrowserPanel"
                    Width="250"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Item Browser"
                               FontWeight="SemiBold" Margin="8,8,8,4"/>
                    <TextBox DockPanel.Dock="Top" x:Name="BrowserSearchBox"
                             Watermark="Search items..."
                             Margin="8,4"/>
                    <TreeView x:Name="ItemBrowserTree" Margin="4,4">
                        <!-- Will be populated when module is loaded -->
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns"/>

            <!-- Editor Area -->
            <Border Grid.Column="2">
                <Panel>
                    <!-- Empty state message -->
                    <StackPanel x:Name="EmptyStatePanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="True">
                        <TextBlock Text="No item loaded"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="Open a .uti file to begin editing"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                        <Button Content="Open File..."
                                Click="OnOpenClick"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Editor content (shown when file is loaded) -->
                    <ScrollViewer x:Name="EditorContent" IsVisible="False">
                        <StackPanel Margin="16" Spacing="16">

                            <!-- Basic Properties -->
                            <TextBlock Text="Basic Properties" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  Margin="0,0,0,8">
                                <Grid.Styles>
                                    <Style Selector="TextBlock.label">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0,0,8,8"/>
                                    </Style>
                                    <Style Selector="TextBox">
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                    </Style>
                                </Grid.Styles>

                                <!-- Name -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Classes="label"/>
                                <controls:SpellCheckTextBox Grid.Row="0" Grid.Column="1"
                                         x:Name="NameTextBox"
                                         Text="{Binding Name, Mode=TwoWay}"
                                         Watermark="Item name"/>

                                <!-- Tag -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tag" Classes="label"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         x:Name="TagTextBox"
                                         Text="{Binding Tag, Mode=TwoWay}"
                                         MaxLength="32"
                                         Watermark="Item tag (max 32 chars)"/>

                                <!-- ResRef (synced from filename, read-only) -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="ResRef" Classes="label"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         x:Name="ResRefTextBox"
                                         Text="{Binding ResRef, Mode=OneWay}"
                                         IsReadOnly="True"
                                         MaxLength="16"
                                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                         ToolTip.Tip="Resource reference (auto-set from filename). Use Save As to change."
                                         Watermark="(set from filename)"/>

                                <!-- Base Item Type -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Base Type" Classes="label"/>
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          x:Name="BaseItemComboBox"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"
                                          SelectionChanged="OnBaseItemSelectionChanged"/>

                                <!-- Cost -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Cost" Classes="label"/>
                                <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,16,Auto,*" Margin="0,0,0,8">
                                    <NumericUpDown Grid.Column="0"
                                                   x:Name="CostUpDown"
                                                   Value="{Binding Cost, Mode=TwoWay}"
                                                   Minimum="0" Maximum="999999999"
                                                   FormatString="N0"
                                                   Watermark="Base cost"/>
                                    <TextBlock Grid.Column="2" Text="Additional" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <NumericUpDown Grid.Column="3"
                                                   x:Name="AddCostUpDown"
                                                   Value="{Binding AddCost, Mode=TwoWay}"
                                                   Minimum="0" Maximum="999999999"
                                                   FormatString="N0"
                                                   Watermark="Additional cost"/>
                                </Grid>

                                <!-- Palette Category -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Category" Classes="label"/>
                                <ComboBox Grid.Row="5" Grid.Column="1"
                                          x:Name="PaletteCategoryComboBox"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"
                                          SelectionChanged="OnPaletteCategorySelectionChanged"/>

                                <!-- Item Type Description (read-only from 2DA) -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Type Info" Classes="label"/>
                                <TextBox Grid.Row="6" Grid.Column="1"
                                         x:Name="BaseItemDescriptionText"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="40"
                                         MaxHeight="120"
                                         Watermark="(no description available)"
                                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>

                            <!-- Unidentified Description -->
                            <TextBlock Text="Unidentified Description" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            <TextBlock Text="Shown to players before the item is identified"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,0,0,4"/>
                            <controls:SpellCheckTextBox
                                x:Name="DescriptionTextBox"
                                Text="{Binding Description, Mode=TwoWay}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="60"
                                MaxHeight="200"
                                Watermark="Unidentified description (visible before Lore check)"
                                Margin="0,0,0,8"/>

                            <!-- Identified Description -->
                            <TextBlock Text="Identified Description" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,2"/>
                            <TextBlock Text="Shown to players after the item is identified"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,0,0,4"/>
                            <controls:SpellCheckTextBox
                                x:Name="DescIdentifiedTextBox"
                                Text="{Binding DescIdentified, Mode=TwoWay}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                MinHeight="60"
                                MaxHeight="200"
                                Watermark="Identified description (visible after Lore check)"
                                Margin="0,0,0,8"/>

                            <Separator/>

                            <!-- Flags & Quantities -->
                            <TextBlock Text="Flags and Quantities" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto"
                                  Margin="0,0,0,8">
                                <!-- Flags row -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Flags"
                                           VerticalAlignment="Center" Margin="0,0,8,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,8">
                                    <CheckBox x:Name="PlotCheckBox"
                                              Content="Plot"
                                              IsChecked="{Binding Plot, Mode=TwoWay}"
                                              ToolTip.Tip="Cannot be dropped or sold"/>
                                    <CheckBox x:Name="CursedCheckBox"
                                              Content="Cursed"
                                              IsChecked="{Binding Cursed, Mode=TwoWay}"
                                              ToolTip.Tip="Cannot be unequipped"/>
                                    <CheckBox x:Name="StolenCheckBox"
                                              Content="Stolen"
                                              IsChecked="{Binding Stolen, Mode=TwoWay}"
                                              ToolTip.Tip="Marked as stolen"/>
                                    <CheckBox x:Name="IdentifiedCheckBox"
                                              Content="Identified"
                                              IsChecked="{Binding Identified, Mode=TwoWay}"
                                              ToolTip.Tip="Already identified (no lore check needed)"/>
                                    <CheckBox x:Name="DropableCheckBox"
                                              Content="Droppable"
                                              IsChecked="{Binding Dropable, Mode=TwoWay}"
                                              ToolTip.Tip="Item can be dropped from inventory"/>
                                </StackPanel>

                                <!-- Stack Size -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Stack Size"
                                           VerticalAlignment="Center" Margin="0,0,8,8"/>
                                <NumericUpDown Grid.Row="1" Grid.Column="1"
                                               x:Name="StackSizeUpDown"
                                               Value="{Binding StackSize, Mode=TwoWay}"
                                               Minimum="1" Maximum="65535"
                                               FormatString="N0"
                                               HorizontalAlignment="Left"
                                               Width="150"
                                               Margin="0,0,0,8"/>

                                <!-- Charges -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Charges"
                                           VerticalAlignment="Center" Margin="0,0,8,8"/>
                                <NumericUpDown Grid.Row="2" Grid.Column="1"
                                               x:Name="ChargesUpDown"
                                               Value="{Binding Charges, Mode=TwoWay}"
                                               Minimum="0" Maximum="255"
                                               FormatString="N0"
                                               HorizontalAlignment="Left"
                                               Width="150"
                                               Margin="0,0,0,8"/>
                            </Grid>

                            <!-- Appearance (collapsible, conditional on base item type) -->
                            <Expander x:Name="AppearanceExpander" Header="Appearance" IsExpanded="True" IsVisible="False" Margin="0,0,0,8">
                                <StackPanel Spacing="8" Margin="0,4,0,0">

                                    <!-- Model Parts (ModelType 0/1/2) -->
                                    <StackPanel x:Name="ModelPartsPanel" IsVisible="False">
                                        <TextBlock Text="Model Parts" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,8">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Part 1"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                           x:Name="ModelPart1UpDown"
                                                           Value="{Binding ModelPart1, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           HorizontalAlignment="Left" Width="150"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Part 2"
                                                       x:Name="ModelPart2Label"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                           x:Name="ModelPart2UpDown"
                                                           Value="{Binding ModelPart2, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           HorizontalAlignment="Left" Width="150"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Part 3"
                                                       x:Name="ModelPart3Label"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                           x:Name="ModelPart3UpDown"
                                                           Value="{Binding ModelPart3, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           HorizontalAlignment="Left" Width="150"
                                                           Margin="0,0,0,8"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Colors (ModelType 1 or 3) -->
                                    <StackPanel x:Name="ColorsPanel" IsVisible="False">
                                        <TextBlock Text="Colors" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid ColumnDefinitions="120,*,16,120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,8">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cloth 1"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                           Value="{Binding Cloth1Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Cloth 2"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="0" Grid.Column="4"
                                                           Value="{Binding Cloth2Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Leather 1"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                           Value="{Binding Leather1Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Leather 2"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="4"
                                                           Value="{Binding Leather2Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Metal 1"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                           Value="{Binding Metal1Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Metal 2"
                                                       VerticalAlignment="Center" Margin="0,0,8,8"/>
                                            <NumericUpDown Grid.Row="2" Grid.Column="4"
                                                           Value="{Binding Metal2Color, Mode=TwoWay}"
                                                           Minimum="0" Maximum="255"
                                                           FormatString="N0"
                                                           Margin="0,0,0,8"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Armor Parts (ModelType 3 only) -->
                                    <StackPanel x:Name="ArmorPartsPanel" IsVisible="False">
                                        <TextBlock Text="Armor Parts" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid x:Name="ArmorPartsGrid" ColumnDefinitions="120,*,16,120,*" Margin="0,0,0,8">
                                            <!-- Populated dynamically in code-behind -->
                                        </Grid>
                                    </StackPanel>

                                </StackPanel>
                            </Expander>

                            <!-- Item Properties Editor -->
                            <TextBlock Text="Item Properties" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,*" MinHeight="300" Margin="0,0,0,8">
                                <!-- Left: Available Properties -->
                                <Border Grid.Column="0" Grid.RowSpan="2"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="Available Properties"
                                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox DockPanel.Dock="Top" x:Name="PropertySearchBox"
                                                 Watermark="Search properties..."
                                                 Margin="0,0,0,4"/>
                                        <TreeView x:Name="AvailablePropertiesTree"
                                                  SelectionChanged="OnAvailablePropertySelectionChanged"/>
                                    </DockPanel>
                                </Border>

                                <!-- Center: Add/Remove buttons -->
                                <StackPanel Grid.Column="1" Grid.RowSpan="2"
                                            VerticalAlignment="Center"
                                            Margin="8,0">
                                    <Button x:Name="AddPropertyButton"
                                            Content="Add &gt;"
                                            Click="OnAddPropertyClick"
                                            Width="80"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,0,0,8"
                                            IsEnabled="False"
                                            ToolTip.Tip="Add selected property with configured values"/>
                                    <Button x:Name="AddCheckedButton"
                                            Content="Add Checked &gt;"
                                            Click="OnAddCheckedClick"
                                            Width="100"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,0,0,8"
                                            IsEnabled="False"
                                            ToolTip.Tip="Add all checked properties with default values"/>
                                    <Button x:Name="EditPropertyButton"
                                            Content="Edit"
                                            Click="OnEditPropertyClick"
                                            Width="80"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,0,0,8"
                                            IsEnabled="False"/>
                                    <Button x:Name="RemovePropertyButton"
                                            Content="&lt; Remove"
                                            Click="OnRemovePropertyClick"
                                            Width="80"
                                            HorizontalContentAlignment="Center"
                                            Margin="0,0,0,8"
                                            IsEnabled="False"/>
                                    <Button x:Name="ClearAllPropertiesButton"
                                            Content="Clear All"
                                            Click="OnClearAllPropertiesClick"
                                            Width="80"
                                            HorizontalContentAlignment="Center"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- Right: Assigned Properties -->
                                <Border Grid.Column="2" Grid.RowSpan="2"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="Assigned Properties"
                                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <ListBox x:Name="AssignedPropertiesList"
                                                 SelectionMode="Multiple,Toggle"
                                                 SelectionChanged="OnAssignedPropertySelectionChanged"/>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <!-- Cascading Dropdowns for property configuration -->
                            <Border x:Name="PropertyConfigPanel" IsVisible="False"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <Grid.Styles>
                                        <Style Selector="TextBlock.config-label">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0,0,8,8"/>
                                        </Style>
                                    </Grid.Styles>

                                    <!-- Selected property type name -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Property" Classes="config-label"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SelectedPropertyName"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,0,8"/>

                                    <!-- Subtype dropdown -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="SubtypeLabel"
                                               Text="Subtype" Classes="config-label"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="SubtypeComboBox"
                                              HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                                    <!-- Cost Value dropdown -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="CostValueLabel"
                                               Text="Value" Classes="config-label"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CostValueComboBox"
                                              HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                                    <!-- Param Value dropdown -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ParamValueLabel"
                                               Text="Parameter" Classes="config-label"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ParamValueComboBox"
                                              HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                                    <!-- Apply Edit button (only visible in edit mode) -->
                                    <Button Grid.Row="4" Grid.Column="1"
                                            x:Name="ApplyEditButton"
                                            Content="Apply Changes"
                                            Click="OnApplyEditClick"
                                            HorizontalAlignment="Left"
                                            IsVisible="False"
                                            Margin="0,0,0,4"/>
                                </Grid>
                            </Border>

                            <!-- Item Statistics -->
                            <StackPanel x:Name="ItemStatisticsPanel" IsVisible="False">
                                <TextBlock Text="Item Statistics" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="ItemStatisticsText"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         MaxHeight="200"
                                         Watermark="No properties assigned"
                                         Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- Local Variables -->
                            <Expander Header="Local Variables" IsExpanded="False" Margin="0,0,0,8">
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Add" Click="OnAddVariable"/>
                                                <Button Content="Remove" Click="OnRemoveVariable"/>
                                            </StackPanel>
                                            <TextBlock x:Name="VariableValidationText"
                                                       Foreground="#FF4444"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       IsVisible="False"/>
                                        </StackPanel>

                                        <DataGrid x:Name="VariablesGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserReorderColumns="True"
                                                  CanUserResizeColumns="True"
                                                  CanUserSortColumns="True"
                                                  IsReadOnly="False"
                                                  SelectionMode="Extended"
                                                  GridLinesVisibility="Horizontal"
                                                  MaxHeight="180">
                                            <DataGrid.Resources>
                                                <vm:BoolToErrorBrushConverter x:Key="BoolToErrorBrushConverter"/>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Name" Width="120">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBox Text="{Binding Name}"
                                                                         HorizontalAlignment="Stretch"
                                                                         MinWidth="80"
                                                                         BorderBrush="{Binding HasError, Converter={StaticResource BoolToErrorBrushConverter}}"/>
                                                                <TextBlock Text="{Binding ErrorMessage}"
                                                                           Foreground="{DynamicResource ThemeError}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           IsVisible="{Binding HasError}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Type" Width="80">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox SelectedIndex="{Binding TypeIndex}" Margin="0"
                                                                      HorizontalAlignment="Stretch">
                                                                <ComboBoxItem Content="Int"/>
                                                                <ComboBoxItem Content="Float"/>
                                                                <ComboBoxItem Content="String"/>
                                                            </ComboBox>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Value" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <NumericUpDown Value="{Binding IntValue}" IsVisible="{Binding IsIntType}" Minimum="-2147483648" Maximum="2147483647"/>
                                                                <NumericUpDown Value="{Binding FloatValue}" IsVisible="{Binding IsFloatType}" Increment="0.001" FormatString="F3"/>
                                                                <TextBox Text="{Binding StringValue}" IsVisible="{Binding IsStringType}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>
                            </Expander>

                            <!-- Developer Comments -->
                            <Expander Header="Developer Comments" IsExpanded="False" Margin="0,0,0,8">
                                <TextBox x:Name="CommentTextBox"
                                         Text="{Binding Comment, Mode=TwoWay}"
                                         Watermark="Designer comment (not visible in-game)"
                                         AcceptsReturn="True"
                                         MinHeight="60"
                                         MaxHeight="200"
                                         TextWrapping="Wrap"
                                         Margin="0,4,0,0"/>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Panel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
